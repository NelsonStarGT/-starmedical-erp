model Encounter {
  id              String                  @id
  patientId       String
  status          String                  @default("draft")
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  closedAt        DateTime?
  closedById      String?
  reconsultations EncounterReconsulta[]
  results         EncounterResult[]
  documents       EncounterDocument[]
  supplies        EncounterSupply[]
  orderRequests   EncounterOrderRequest[]

  @@index([patientId])
  @@index([status, createdAt])
}

model EncounterOrderRequest {
  id                String    @id
  encounterId       String
  modality          String
  assignedToService String?
  serviceId         String?
  serviceCode       String?
  title             String
  quantity          Int
  notes             String?
  priority          String
  status            String
  createdAt         DateTime  @default(now())
  createdByName     String?
  updatedAt         DateTime  @default(now())
  updatedByName     String?
  encounter         Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, createdAt])
  @@index([modality])
  @@index([status])
}

model EncounterSupply {
  id              String    @id
  encounterId     String
  source          String
  inventoryItemId String?
  sku             String?
  name            String
  unit            String?
  quantity        Int
  unitPrice       Decimal?  @db.Decimal(12, 4)
  notes           String?
  createdAt       DateTime  @default(now())
  createdByName   String?
  encounter       Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, createdAt])
  @@index([source])
}

model EncounterReconsulta {
  id                    String    @id
  encounterId           String
  type                  String
  sourceResultId        String?
  sourceResultTitle     String?
  entryTitle            String
  noteRichJson          Json
  noteRichHtml          String
  interpretation        String
  conduct               String
  therapeuticAdjustment String
  createdAt             DateTime  @default(now())
  authorId              String?
  authorName            String?
  encounter             Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, createdAt])
  @@index([type])
}

model EncounterResult {
  id          String    @id
  encounterId String
  type        String
  status      String
  title       String
  performedAt DateTime
  pdfUrl      String?
  imageUrls   Json
  values      Json
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, performedAt])
  @@index([status])
}

model EncounterDocument {
  id          String    @id
  encounterId String
  kind        String
  title       String
  storageRef  String?
  createdAt   DateTime  @default(now())
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, createdAt])
  @@index([kind])
}

