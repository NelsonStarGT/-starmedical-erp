  warnings                HrEmployeeWarning[]
  compensationBonuses     CompensationBonus[]
  compensationHistory     HrCompensationHistory[]
  branchAssignments       EmployeeBranchAssignment[]
  documents               EmployeeDocument[]
  engagements             EmployeeEngagement[]
  EmployeeEvaluation      EmployeeEvaluation[]
  payrollEmployees        PayrollEmployee[]
  payrollRunEmployees     PayrollRunEmployee[]
  positionAssignments     EmployeePositionAssignment[]
  EmployeeShiftAssignment EmployeeShiftAssignment[]
  primaryLegalEntity      LegalEntity?                 @relation(fields: [primaryLegalEntityId], references: [id])
  user                    User?                        @relation("EmployeeUser", fields: [userId], references: [id])
  LeaveBalance            LeaveBalance[]
  LeaveRequest            LeaveRequest[]
  notifications           Notification[]
  professionalLicense     ProfessionalLicense?
  TimeClockLog            TimeClockLog[]
  HrAttendanceEvent       HrAttendanceEvent[]
  HrPayrollLine           HrPayrollLine[]
  AttendancePunchToken    AttendancePunchToken[]
  EmployeeSiteAssignment  EmployeeSiteAssignment[]

  @@index([employeeCode])
  @@index([dpi])
  @@index([primaryLegalEntityId])
}

model CompensationBonus {
  id           String              @id @default(cuid())
  employeeId   String
  engagementId String?
  name         String
  amount       Decimal             @db.Decimal(12, 2)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  employee     HrEmployee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  engagement   EmployeeEngagement? @relation(fields: [engagementId], references: [id])

  @@index([employeeId])
  @@index([engagementId])
}

model EmployeeEngagement {
  id                    String                 @id @default(cuid())
  employeeId            String
  legalEntityId         String
  employmentType        HrEmploymentType
  status                HrEmployeeStatus       @default(ACTIVE)
  startDate             DateTime
  endDate               DateTime?
  isPayrollEligible     Boolean                @default(true)
  isPrimary             Boolean                @default(false)
  compensationAmount    Decimal?               @db.Decimal(12, 2)
  compensationCurrency  String                 @default("GTQ")
  compensationFrequency PayFrequency           @default(MONTHLY)
  compensationNotes     String?
  createdById           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  baseSalary            Decimal?               @db.Decimal(12, 2)
  baseAllowance         Decimal?               @db.Decimal(12, 2)
  paymentScheme         HrPaymentScheme        @default(MONTHLY)
  compensations         EmployeeCompensation[]
  employee              HrEmployee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  legalEntity           LegalEntity            @relation(fields: [legalEntityId], references: [id])
  payrollEntries        PayrollRunEntry[]
  payrollEmployees      PayrollEmployee[]
  compensationBonuses   CompensationBonus[]

  @@index([employeeId])
  @@index([legalEntityId])
  @@index([status])
}

model HrCompensationHistory {
  id            String           @id @default(cuid())
  employeeId    String
  effectiveFrom DateTime         @default(now())
  prevSalary    Decimal?         @db.Decimal(12, 2)
  newSalary     Decimal?         @db.Decimal(12, 2)
  prevAllowance Decimal?         @db.Decimal(12, 2)
  newAllowance  Decimal?         @db.Decimal(12, 2)
  prevPayScheme HrPaymentScheme?
  newPayScheme  HrPaymentScheme?
  comments      String?
  createdById   String?
  createdAt     DateTime         @default(now())
  employee      HrEmployee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, createdAt])
}

model EmployeeCompensation {
  id            String             @id @default(cuid())
  engagementId  String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  baseSalary    Decimal?           @db.Decimal(12, 2)
  currency      String             @default("GTQ")
  payFrequency  PayFrequency
  allowances    Json?
  deductions    Json?
  isActive      Boolean            @default(true)
  createdById   String?
  createdAt     DateTime           @default(now())
  paymentScheme HrPaymentScheme    @default(MONTHLY)
  engagement    EmployeeEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId, effectiveFrom])
}

model EmployeeBranchAssignment {
  id          String     @id @default(cuid())
  employeeId  String
  branchId    String
  isPrimary   Boolean    @default(false)
  startDate   DateTime?
  endDate     DateTime?
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  code        String?
  branch      Branch     @relation(fields: [branchId], references: [id])
  employee    HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, branchId])
  @@index([employeeId])
  @@index([branchId])
}

model EmployeePositionAssignment {
  id           String        @id @default(cuid())
  employeeId   String
  positionId   String
  departmentId String?
  isPrimary    Boolean       @default(false)
  startDate    DateTime?
  endDate      DateTime?
  notes        String?
  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  department   HrDepartment? @relation(fields: [departmentId], references: [id])
  employee     HrEmployee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  position     HrPosition    @relation(fields: [positionId], references: [id])

  @@index([employeeId])
  @@index([positionId])
}

model EmployeeDocument {
  id               String                    @id @default(cuid())
  employeeId       String
  type             HrEmployeeDocumentType
  title            String
  notes            String?
  retentionUntil   DateTime?
  isArchived       Boolean                   @default(false)
  currentVersionId String?                   @unique
  createdById      String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  visibility       HrDocumentVisibility      @default(PERSONAL)
  currentVersion   EmployeeDocumentVersion?  @relation("CurrentEmployeeDocumentVersion", fields: [currentVersionId], references: [id])
  employee         HrEmployee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  versions         EmployeeDocumentVersion[] @relation("DocumentVersions")

  @@index([employeeId])
}

model EmployeeDocumentVersion {
  id               String            @id @default(cuid())
  documentId       String
  versionNumber    Int
  fileUrl          String
  issuedAt         DateTime?
  deliveredAt      DateTime?
  expiresAt        DateTime?
  notes            String?
  uploadedById     String?
  createdAt        DateTime          @default(now())
  canEmployeeView  Boolean           @default(false)
  viewGrantedUntil DateTime?
  currentFor       EmployeeDocument? @relation("CurrentEmployeeDocumentVersion")
  document         EmployeeDocument  @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy       User?             @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  @@unique([documentId, versionNumber])
  @@index([expiresAt])
}

model ProfessionalLicense {
  id            String     @id @default(cuid())
  employeeId    String     @unique
  applies       Boolean    @default(false)
  licenseNumber String?    @map("number")
  issuedAt      DateTime?
  expiresAt     DateTime?
  issuingEntity String?
  fileUrl       String?
  reminderDays  Int?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employee      HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String               @id @default(cuid())
  type        NotificationType
  severity    NotificationSeverity @default(INFO)
  title       String
  description String?
  entityId    String?
  entityType  String?
  employeeId  String?
  dueAt       DateTime?
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime             @default(now())
  employee    HrEmployee?          @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([type, dueAt])
}

model PayrollRun {
  id               String                 @id @default(cuid())
  code             String                 @unique
  legalEntityId    String
  branchId         String?
  runType          PayrollRunType         @default(REGULAR)
  periodStart      DateTime
  periodEnd        DateTime
  status           PayrollRunStatus       @default(DRAFT)
  notes            String?
  totalGross       Decimal?               @db.Decimal(14, 2)
  totalDeductions  Decimal?               @db.Decimal(14, 2)
  totalNet         Decimal?               @db.Decimal(14, 2)
  approvedAt       DateTime?
  approvedById     String?
  createdById      String?
  publishedAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  approvedBy       User?                  @relation("PayrollRunApprovedBy", fields: [approvedById], references: [id])
  createdBy        User?                  @relation("PayrollRunCreatedBy", fields: [createdById], references: [id])
  legalEntity      LegalEntity            @relation(fields: [legalEntityId], references: [id])
  branch           Branch?                @relation(fields: [branchId], references: [id])
  entries          PayrollRunEntry[]
  payrollEmployees PayrollEmployee[]
  runEmployees     PayrollRunEmployee[]
  financeRecords   PayrollFinanceRecord[]

  @@index([legalEntityId])
  @@index([branchId])
  @@index([status])
}

model PayrollRunEntry {
  id                   String             @id @default(cuid())
  payrollRunId         String
  engagementId         String
  compensationSnapshot Json?
  grossAmount          Decimal?           @db.Decimal(14, 2)
  netAmount            Decimal?           @db.Decimal(14, 2)
  notes                String?
  createdAt            DateTime           @default(now())
  engagement           EmployeeEngagement @relation(fields: [engagementId], references: [id])
  payrollRun           PayrollRun         @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@index([payrollRunId])
  @@index([engagementId])
}

model PayrollEmployee {
  id              String                   @id @default(cuid())
  payrollRunId    String
  employeeId      String
  engagementId    String?
  employmentType  HrEmploymentType
  baseSalary      Decimal?                 @db.Decimal(14, 2)
  workedDays      Int?
  workedHours     Decimal?                 @db.Decimal(8, 2)
  overtimeHours   Decimal?                 @db.Decimal(8, 2)
  grossAmount     Decimal?                 @db.Decimal(14, 2)
  totalDeductions Decimal?                 @db.Decimal(14, 2)
  netAmount       Decimal?                 @db.Decimal(14, 2)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  payrollRun      PayrollRun               @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee        HrEmployee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  engagement      EmployeeEngagement?      @relation(fields: [engagementId], references: [id])
  concepts        PayrollEmployeeConcept[]
  financeRecords  PayrollFinanceRecord[]

  @@index([payrollRunId])
  @@index([employeeId])
}

model PayrollRunEmployee {
  id               String               @id @default(cuid())
  payrollRunId     String
  employeeId       String
  paymentStatus    PayrollPaymentStatus @default(PENDING)
  paidAt           DateTime?
  paidByUserId     String?
  signedAt         DateTime?
  signedByUserId   String?
  signatureFileKey String?
  computedJson     Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  payrollRun       PayrollRun           @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee         HrEmployee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([payrollRunId])
  @@index([employeeId])
}

model PayrollConcept {
  id          String                   @id @default(cuid())
  code        String                   @unique
  type        PayrollConceptType
  description String
  isTaxable   Boolean                  @default(true)
  isEditable  Boolean                  @default(false)
  isActive    Boolean                  @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  items       PayrollEmployeeConcept[]
}

model PayrollEmployeeConcept {
  id                String          @id @default(cuid())
  payrollEmployeeId String
  conceptId         String
  quantity          Decimal         @db.Decimal(10, 2)
  amount            Decimal         @db.Decimal(14, 2)
  total             Decimal         @db.Decimal(14, 2)
  createdAt         DateTime        @default(now())
  payrollEmployee   PayrollEmployee @relation(fields: [payrollEmployeeId], references: [id], onDelete: Cascade)
  concept           PayrollConcept  @relation(fields: [conceptId], references: [id])

  @@index([payrollEmployeeId])
  @@index([conceptId])
}

model PayrollFinanceRecord {
  id                String           @id @default(cuid())
  payrollRunId      String
  payrollEmployeeId String?
  payableId         String?
  amount            Decimal          @db.Decimal(14, 2)
  createdAt         DateTime         @default(now())
  payrollRun        PayrollRun       @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  payrollEmployee   PayrollEmployee? @relation(fields: [payrollEmployeeId], references: [id], onDelete: Cascade)
  payable           Payable?         @relation(fields: [payableId], references: [id])

  @@index([payrollRunId])
  @@index([payrollEmployeeId])
  @@index([payableId])
}

model AttendanceComputed {
  id         String           @id
  employeeId String
  date       DateTime
  totalHours Decimal?         @db.Decimal(6, 2)
  status     AttendanceStatus
  color      AttendanceColor
  notes      String?
