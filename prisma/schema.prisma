generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                       @id @default(cuid())
  email                        String                       @unique
  name                         String?
  passwordHash                 String
  isActive                     Boolean                      @default(true)
  branchId                     String?
  tenantId                     String?
  profile                      UserProfile?
  tenant                       Tenant?                      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  auditLogs                    AuditLog[]                   @relation("AuditActor")
  resolvedSystemEvents         SystemEventLog[]             @relation("SystemEventResolvedBy")
  b2bProposalsCreated          B2BProposalDoc[]             @relation("B2BProposalCreatedBy")
  b2bProposalsUpdated          B2BProposalDoc[]             @relation("B2BProposalUpdatedBy")
  dealsOwned                   CrmDeal[]                    @relation("DealOwnerUser")
  uploadedDocuments            EmployeeDocumentVersion[]    @relation("DocumentUploadedBy")
  EmployeeEvaluation           EmployeeEvaluation[]
  fileAssets                   FileAsset[]
  employee                     HrEmployee?                  @relation("EmployeeUser")
  LeaveRequest                 LeaveRequest[]
  MembershipException          MembershipException[]
  payrollRunsApproved          PayrollRun[]                 @relation("PayrollRunApprovedBy")
  payrollRunsCreated           PayrollRun[]                 @relation("PayrollRunCreatedBy")
  deliveries                   QuoteDelivery[]              @relation("DeliveryActor")
  ruleEvaluations              RuleEvaluationLog[]
  roles                        UserRole[]
  userPermissions              UserPermission[]
  createdAttendanceRawEvents   AttendanceRawEvent[]         @relation("AttendanceRawEventCreatedBy")
  resolvedAttendanceIncidents  AttendanceIncident[]         @relation("AttendanceIncidentResolvedBy")
  approvedAttendance           AttendanceDay[]              @relation("AttendanceApprovedBy")
  closedAttendance             AttendanceDay[]              @relation("AttendanceClosedBy")
  reviewedOvertime             OvertimeRequest[]            @relation("OvertimeReviewedBy")
  disciplinaryActionsCreated   DisciplinaryAction[]         @relation("DisciplinaryActionCreatedBy")
  disciplinaryActionsApproved  DisciplinaryAction[]         @relation("DisciplinaryActionApprovedBy")
  hrWarningsCreated            HrEmployeeWarning[]          @relation("HrWarningCreatedBy")
  attendancePunchTokensCreated AttendancePunchToken[]       @relation("AttendancePunchTokenCreatedBy")
  attendanceRecordsCreated     AttendanceRecord[]           @relation("AttendanceRecordCreatedBy")
  diagnosticOrdersCreated      DiagnosticOrder[]            @relation("DiagnosticOrdersCreated")
  receptionNotesCreated        ReceptionNote[]              @relation("ReceptionNotesCreated")
  receptionAppointmentVitals   ReceptionAppointmentVitals[]
  receptionVisitVitals         ReceptionVisitVitals[]       @relation("ReceptionVisitVitalsCreatedBy")
  receptionSlaConfigsUpdated   ReceptionSlaConfig[]         @relation("ReceptionSlaUpdatedBy")
  labSpecimensCollected        LabSpecimen[]                @relation("SpecimenCollector")
  labResultsEntered            LabResult[]                  @relation("LabResultEnteredBy")
  labResultsValidated          LabResult[]                  @relation("LabResultValidatedBy")
  imagingReportsAuthored       ImagingReport[]              @relation("ImagingReportAuthor")
  imagingReportsSigned         ImagingReport[]              @relation("ImagingReportSigner")
  labTestOrdersCreated         LabTestOrder[]               @relation("LabTestOrdersCreated")
  labTestOrdersSent            LabTestOrder[]               @relation("LabTestOrdersSent")
  labTestItemsCreated          LabTestItem[]                @relation("LabTestItemsCreated")
  labSamplesCreated            LabSample[]                  @relation("LabSamplesCreated")
  labTestResultsEntered        LabTestResult[]              @relation("LabTestResultEnteredBy")
  labTestResultsValidated      LabTestResult[]              @relation("LabTestResultValidatedBy")
  labTemplatesCreated          LabTemplate[]                @relation("LabTemplatesCreated")
  labTemplatesV2Created        LabTemplateV2[]              @relation("LabTemplatesV2Created")
  labMessageLogsCreated        LabMessageLog[]              @relation("LabMessagesCreated")
  labInstrumentsCreated        LabInstrument[]              @relation("LabInstrumentsCreated")
  labAccesses                  LabAccess[]
  labOtpChallenges             LabOtpChallenge[]
  clientDocumentsApproved      ClientDocument[]             @relation("ClientDocApprovedBy")
  clientDocumentsRejected      ClientDocument[]             @relation("ClientDocRejectedBy")
  clientAuditEvents            ClientAuditEvent[]           @relation("ClientAuditActor")
  clientNotes                  ClientNote[]                 @relation("ClientNoteActor")
  registrationInvitesCreated   ClientRegistrationInvite[]   @relation("ClientRegistrationInviteCreatedBy")
  selfRegistrationsReviewed    ClientSelfRegistration[]     @relation("ClientSelfRegistrationReviewedBy")
  branchAccesses               UserBranchAccess[]
  visitsCreated                Visit[]                      @relation("VisitCreatedBy")
  visitsUpdated                Visit[]                      @relation("VisitUpdatedBy")
  visitEvents                  VisitEvent[]                 @relation("VisitEventActor")
  queuesCreated                Queue[]                      @relation("QueueCreatedBy")
  queuesUpdated                Queue[]                      @relation("QueueUpdatedBy")
  queueItemsCreated            QueueItem[]                  @relation("QueueItemCreatedBy")
  queueItemsUpdated            QueueItem[]                  @relation("QueueItemUpdatedBy")
  queueItemsAssigned           QueueItem[]                  @relation("QueueItemAssignee")
  serviceRequestsRequested     ServiceRequest[]             @relation("ServiceRequestRequestedBy")
  serviceRequestsAssigned      ServiceRequest[]             @relation("ServiceRequestAssignedTo")
  operationalIncidentsReported OperationalIncident[]        @relation("OperationalIncidentReportedBy")
  operationalIncidentsResolved OperationalIncident[]        @relation("OperationalIncidentResolvedBy")
  tenantThemeConfigsUpdated    TenantThemeConfig[]          @relation("TenantThemeUpdatedBy")
  systemFeatureConfigsUpdated  SystemFeatureConfig[]        @relation("SystemFeatureUpdatedBy")
}

model Department {
  id             String         @id @default(cuid())
  name           String         @unique
  isActive       Boolean        @default(true)
  municipalities Municipality[]
  users          UserProfile[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Municipality {
  id           String        @id @default(cuid())
  name         String
  departmentId String
  isActive     Boolean       @default(true)
  department   Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users        UserProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([departmentId, name])
}

model UserProfile {
  id               String        @id @default(cuid())
  userId           String        @unique
  phone            String?
  dpi              String?
  jobRoleId        String?
  departmentId     String?
  municipalityId   String?
  housingSector    String?
  addressLine      String?
  addressReference String?
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobRole          JobRole?      @relation(fields: [jobRoleId], references: [id])
  department       Department?   @relation(fields: [departmentId], references: [id])
  municipality     Municipality? @relation(fields: [municipalityId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([jobRoleId])
  @@index([departmentId])
  @@index([municipalityId])
}

model JobRole {
  id        String        @id @default(cuid())
  name      String        @unique
  isActive  Boolean       @default(true)
  profiles  UserProfile[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
  tenantId    String?
  actorUserId String?
  actorRole   String?
  action      String
  entityType  String
  entityId    String
  ip          String?
  userAgent   String?
  metadata    Json?
  before      Json?
  after       Json?
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([timestamp])
  @@index([createdAt])
  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([actorUserId])
}

model SystemEventLog {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  tenantId         String?
  domain           String
  eventType        String
  severity         String
  code             String?
  resource         String?
  messageShort     String
  digest           String
  metaJson         Json?
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolutionNote   String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  resolvedByUser   User?     @relation("SystemEventResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([domain, createdAt])
  @@index([eventType, createdAt])
  @@index([severity, createdAt])
  @@index([digest])
  @@index([resolvedAt])
  @@index([resolvedByUserId, resolvedAt])
}

model AppointmentType {
  id           String        @id @default(cuid())
  name         String
  description  String?
  durationMin  Int
  color        String?
  status       String        @default("Activo")
  availability Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Room {
  id           String        @id @default(cuid())
  name         String
  branchId     String
  resource     String
  status       String        @default("Activo")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  queueItems   QueueItem[]
}

model WorkSchedule {
  id           String   @id @default(cuid())
  specialistId String
  branchId     String
  weekdays     String[]
  blocks       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductCategory {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  type          String
  order         Int                  @default(0)
  status        String               @default("Activo")
  products      Product[]
  subcategories ProductSubcategory[]
}

model ProductSubcategory {
  id         String          @id @default(cuid())
  categoryId String
  name       String
  slug       String          @unique
  order      Int             @default(0)
  status     String          @default("Activo")
  products   Product[]
  category   ProductCategory @relation(fields: [categoryId], references: [id])
}

model ServiceCategory {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  area          String
  order         Int                  @default(0)
  status        String               @default("Activo")
  services      Service[]
  subcategories ServiceSubcategory[]
}

model ServiceSubcategory {
  id         String          @id @default(cuid())
  categoryId String
  name       String
  slug       String          @unique
  order      Int             @default(0)
  status     String          @default("Activo")
  services   Service[]
  category   ServiceCategory @relation(fields: [categoryId], references: [id])
}

model InventoryArea {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  order      Int       @default(0)
  isExternal Boolean   @default(true)
  products   Product[]
}

model PriceList {
  id        String          @id @default(cuid())
  name      String
  type      String
  estado    String          @default("Activo")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     PriceListItem[]
}

model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  itemType    String
  itemId      String
  precio      Float
  priceList   PriceList @relation(fields: [priceListId], references: [id])
}

model Appointment {
  id                  String                      @id @default(cuid())
  date                DateTime
  durationMin         Int
  patientId           String
  specialistId        String
  branchId            String
  roomId              String?
  typeId              String
  status              AppointmentStatus           @default(PROGRAMADA)
  paymentStatus       PaymentStatus               @default(PENDIENTE)
  paymentIntentId     String?
  portalPaymentStatus PortalPaymentStatus         @default(NONE)
  companyId           String?
  notes               String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  createdById         String
  updatedById         String?
  room                Room?                       @relation(fields: [roomId], references: [id])
  receptionVitals     ReceptionAppointmentVitals?
  type                AppointmentType             @relation(fields: [typeId], references: [id])
  visits              Visit[]
}

model ReceptionAppointmentVitals {
  id              String      @id @default(cuid())
  appointmentId   String      @unique
  siteId          String
  systolicBp      Int
  diastolicBp     Int
  heartRate       Int?
  temperatureC    Float?
  weightKg        Float?
  heightCm        Float?
  observations    String?
  vitalsJson      Json?
  createdByUserId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  site            Branch      @relation(fields: [siteId], references: [id])
  createdByUser   User?       @relation(fields: [createdByUserId], references: [id])

  @@index([siteId])
  @@index([createdByUserId])
}

model ReceptionSlaConfig {
  id                 String                   @id @default(cuid())
  branchId           String                   @unique
  applyToAllAreas    Boolean                  @default(true)
  waitingWarningMin  Int                      @default(20)
  waitingCriticalMin Int                      @default(40)
  inServiceMaxMin    Int                      @default(60)
  calledWarningMin   Int                      @default(10)
  pausedWarningMin   Int                      @default(15)
  updatedByUserId    String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  branch             Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  updatedByUser      User?                    @relation("ReceptionSlaUpdatedBy", fields: [updatedByUserId], references: [id])
  areaConfigs        ReceptionSlaAreaConfig[]

  @@index([updatedByUserId])
}

model ReceptionSlaAreaConfig {
  id                 String             @id @default(cuid())
  slaConfigId        String
  area               OperationalArea
  priority           VisitPriority?
  waitingWarningMin  Int
  waitingCriticalMin Int
  inServiceMaxMin    Int
  calledWarningMin   Int?
  pausedWarningMin   Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  slaConfig          ReceptionSlaConfig @relation(fields: [slaConfigId], references: [id], onDelete: Cascade)

  @@unique([slaConfigId, area, priority])
  @@index([area, priority])
}

model Product {
  id                  String                @id @default(cuid())
  name                String
  code                String                @unique
  categoryId          String
  subcategoryId       String?
  inventoryAreaId     String?
  unit                String?
  cost                Decimal               @default(0) @db.Decimal(12, 4)
  price               Decimal               @default(0) @db.Decimal(12, 4)
  status              String                @default("Activo")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  avgCost             Decimal               @default(0) @db.Decimal(12, 4)
  baseSalePrice       Decimal               @default(0) @db.Decimal(12, 4)
  marginPct           Float?
  comboLinks          ComboProduct[]
  movements           InventoryMovement[]
  category            ProductCategory       @relation(fields: [categoryId], references: [id])
  inventoryArea       InventoryArea?        @relation(fields: [inventoryAreaId], references: [id])
  subcategory         ProductSubcategory?   @relation(fields: [subcategoryId], references: [id])
  stocks              ProductStock[]
  PurchaseOrderItem   PurchaseOrderItem[]
  PurchaseRequestItem PurchaseRequestItem[]
}

model Service {
  id            String              @id @default(cuid())
  name          String
  code          String?             @unique
  categoryId    String
  subcategoryId String?
  price         Float               @default(0)
  durationMin   Int                 @default(0)
  status        String              @default("Activo")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  marginPct     Float?
  comboLinks    ComboService[]
  category      ServiceCategory     @relation(fields: [categoryId], references: [id])
  subcategory   ServiceSubcategory? @relation(fields: [subcategoryId], references: [id])
}

model ProductStock {
  id        String   @id @default(cuid())
  productId String
  branchId  String
  stock     Int
  minStock  Int
  updatedAt DateTime @default(now()) @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([productId, branchId])
}

model InventoryMovement {
  id          String       @id @default(cuid())
  productId   String
  branchId    String
  type        MovementType
  quantity    Int?
  unitCost    Decimal?     @db.Decimal(12, 4)
  salePrice   Decimal?     @db.Decimal(12, 4)
  reference   String?
  reason      String?
  createdById String
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id])
}

model PurchaseRequest {
  id            String                @id @default(cuid())
  code          String                @unique
  branchId      String
  requestedById String
  status        PurchaseRequestStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  orders        PurchaseOrder[]
  items         PurchaseRequestItem[]
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  productId         String
  quantity          Int
  unitId            String?
  supplierId        String?
  notes             String?
  product           Product         @relation(fields: [productId], references: [id])
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  code        String              @unique
  supplierId  String
  branchId    String
  createdById String
  status      PurchaseOrderStatus @default(DRAFT)
  requestId   String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  request     PurchaseRequest?    @relation(fields: [requestId], references: [id])
  items       PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Decimal?      @db.Decimal(12, 2)
  receivedQty     Int           @default(0)
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model Combo {
  id                String         @id @default(cuid())
  name              String
  description       String?
  priceFinal        Decimal        @default(0) @db.Decimal(12, 4)
  costProductsTotal Decimal        @default(0) @db.Decimal(12, 4)
  costCalculated    Decimal        @default(0) @db.Decimal(12, 4)
  imageUrl          String?
  status            String         @default("Activo")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  products          ComboProduct[]
  services          ComboService[]
}

model ComboService {
  id        String  @id @default(cuid())
  comboId   String
  serviceId String
  combo     Combo   @relation(fields: [comboId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@unique([comboId, serviceId])
}

model ComboProduct {
  id        String   @id @default(cuid())
  comboId   String
  productId String
  quantity  Int      @default(1)
  unitCost  Decimal? @db.Decimal(12, 4)
  combo     Combo    @relation(fields: [comboId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([comboId, productId])
}

model InventoryEmailSetting {
  id                 String                   @id @default(cuid())
  isEnabled          Boolean                  @default(true)
  frequency          InventoryReportFrequency
  branchId           String?
  recipients         String
  includeAllProducts Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  lastSentAt         DateTime?
  reportType         InventoryReportType      @default(KARDEX)
  biweeklyMode       String?                  @default("FIXED_DAYS")
  fixedDays          String?
  monthlyDay         Int?
  recipientsJson     String                   @default("[]")
  scheduleType       String                   @default("BIWEEKLY")
  sendTime           String                   @default("23:30")
  startDate          DateTime?
  timezone           String                   @default("America/Guatemala")
  useLastDay         Boolean?                 @default(true)
  oneTimeDate        DateTime?
  oneTimeTime        String?
  sentAt             DateTime?
  logs               InventoryReportLog[]
}

model InventoryEmailSchedule {
  id           String                      @id @default(cuid())
  email        String
  isEnabled    Boolean                     @default(true)
  reportType   InventoryReportType         @default(KARDEX)
  branchId     String?
  scheduleType String                      @default("ONE_TIME")
  sendTime     String                      @default("23:30")
  timezone     String                      @default("America/Guatemala")
  oneTimeDate  DateTime?
  monthlyDay   Int?
  useLastDay   Boolean?                    @default(true)
  biweeklyMode String?                     @default("FIXED_DAYS")
  fixedDays    String?
  startDate    DateTime?
  lastSentAt   DateTime?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  logs         InventoryEmailScheduleLog[]
}

model InventoryEmailScheduleLog {
  id         String                 @id @default(cuid())
  scheduleId String
  reportType InventoryReportType
  periodFrom DateTime
  periodTo   DateTime
  sentAt     DateTime               @default(now())
  status     String
  error      String?
  schedule   InventoryEmailSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

model MailGlobalConfig {
  id         String   @id @default(cuid())
  provider   String?
  smtpHost   String
  smtpPort   Int
  smtpSecure Boolean  @default(true)
  imapHost   String
  imapPort   Int
  imapSecure Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model MailModuleAccount {
  id            String        @id @default(cuid())
  moduleKey     MailModuleKey @unique
  email         String
  username      String
  passwordEnc   String
  fromName      String?
  fromEmail     String?
  isEnabled     Boolean       @default(true)
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime      @updatedAt
  createdAt     DateTime      @default(now())
}

model AppConfig {
  id             String   @id @default(cuid())
  companyName    String
  companyNit     String?
  companyPhone   String?
  companyAddress String?
  logoUrl        String?
  timezone       String   @default("America/Guatemala")
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  brandColor     String?
  openingHours   Json?
}

model InvoiceConfig {
  id                String          @id @default(cuid())
  legalName         String
  nit               String
  fiscalAddress     String?
  defaultTaxRate    Int             @default(12)
  invoiceFooterText String?
  pdfTemplateConfig Json?
  updatedAt         DateTime        @updatedAt
  createdAt         DateTime        @default(now())
  series            InvoiceSeries[]
}

model InvoiceSeries {
  id              String        @id @default(cuid())
  invoiceConfigId String
  code            String
  initialNumber   Int           @default(1)
  currentNumber   Int           @default(1)
  branchId        String?
  isActive        Boolean       @default(true)
  updatedAt       DateTime      @updatedAt
  createdAt       DateTime      @default(now())
  invoiceConfig   InvoiceConfig @relation(fields: [invoiceConfigId], references: [id], onDelete: Cascade)

  @@unique([invoiceConfigId, code, branchId])
}

model Role {
  id            String           @id @default(cuid())
  name          String           @unique
  description   String?
  isSystem      Boolean          @default(false)
  legalEntityId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  permissions   RolePermission[]
  userRoles     UserRole[]
  legalEntity   LegalEntity?     @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  module          String           @default("GENERAL")
  area            String           @default("CORE")
  action          String           @default("READ")
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  roles           RolePermission[]
  userPermissions UserPermission[]

  @@index([module, area, action])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserPermission {
  id            String               @id @default(cuid())
  userId        String
  permissionId  String
  effect        UserPermissionEffect
  reason        String?
  legalEntityId String?
  createdAt     DateTime             @default(now())
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission    Permission           @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  legalEntity   LegalEntity?         @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId, legalEntityId])
}

model AttendanceIntegrationConfig {
  id            String    @id @default(cuid())
  provider      String
  apiUrl        String?
  apiKeyEnc     String?
  enabled       Boolean   @default(true)
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
}

model LabIntegrationConfig {
  id            String    @id @default(cuid())
  provider      String
