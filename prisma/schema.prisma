  requests            QuoteRequest[]
  deliveries          QuoteDelivery[]

  @@index([dealId])
  @@index([dealId, status])
  @@index([dealId, isActive])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  category    String
  productName String
  enlace      String?
  refCode     String?
  description String?
  qty         Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discountPct Decimal? @db.Decimal(5, 2)
  lineTotal   Decimal  @db.Decimal(14, 2)
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteTemplate {
  id                  String          @id @default(cuid())
  name                String
  type                QuoteType
  isDefault           Boolean         @default(false)
  sectionsJson        Json?
  headerJson          Json?
  coverImageUrl       String?
  introLetterHtml     String?
  experienceLogosJson Json?
  termsHtml           String?
  bankAccountsJson    Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  quotes              Quote[]
  settingsAsB2B       QuoteSettings[] @relation("DefaultTemplateB2B")
  settingsAsB2C       QuoteSettings[] @relation("DefaultTemplateB2C")
}

model QuoteSettings {
  id                      Int            @id @default(1)
  defaultTemplateB2BId    String?
  defaultTemplateB2CId    String?
  defaultValidityDays     Int            @default(30)
  defaultIntroLetterHtml  String?
  defaultTermsB2BHtml     String?
  defaultTermsB2CHtml     String?
  defaultFooterJson       Json?
  defaultBankAccountsJson Json?
  defaultChequePayableTo  String?
  defaultPaymentTerms     String?
  defaultDeliveryTime     String?
  defaultDeliveryNote     String?
  showTaxIncludedText     Boolean        @default(true)
  showBankBlock           Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  defaultTemplateB2B      QuoteTemplate? @relation("DefaultTemplateB2B", fields: [defaultTemplateB2BId], references: [id], onDelete: SetNull)
  defaultTemplateB2C      QuoteTemplate? @relation("DefaultTemplateB2C", fields: [defaultTemplateB2CId], references: [id], onDelete: SetNull)
}

model QuoteRequest {
  id          String             @id @default(cuid())
  dealId      String
  createdAt   DateTime           @default(now())
  createdById String?
  services    CrmServiceType[]
  description String
  status      QuoteRequestStatus @default(PENDING)
  quoteId     String?
  deal        CrmDeal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  quote       Quote?             @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([quoteId])
}

model FileAsset {
  id              String           @id @default(cuid())
  storageKey      String           @unique
  originalName    String?
  mimeType        String
  sizeBytes       Int
  sha256          String
  dealId          String?
  createdAt       DateTime         @default(now())
  createdByUserId String?
  createdByUser   User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  deal            CrmDeal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  proposalPdfs    B2BProposalDoc[] @relation("B2BProposalPdfAsset")
  deliveries      QuoteDelivery[]
}

model QuoteDelivery {
  id                String               @id @default(cuid())
  quoteId           String
  dealId            String?
  channel           QuoteDeliveryChannel
  to                Json
  cc                Json?
  bcc               Json?
  subject           String
  bodyText          String?
  bodyHtml          String?
  pdfUrl            String
  pdfHash           String
  pdfVersion        Int                  @default(1)
  fileAssetId       String?
  status            QuoteDeliveryStatus  @default(SENDING)
  provider          String               @default("SMTP")
  providerMessageId String?
  actorUserId       String?
  metadata          Json?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  quote             Quote                @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  deal              CrmDeal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  actorUser         User?                @relation("DeliveryActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  fileAsset         FileAsset?           @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)

  @@index([quoteId, createdAt])
  @@index([status])
  @@index([providerMessageId])
}
