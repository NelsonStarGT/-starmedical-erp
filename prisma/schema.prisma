  HrEmployee HrEmployee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([status])
}

model AttendanceDay {
  id              String                @id @default(cuid())
  employeeId      String
  date            DateTime
  shiftTemplateId String?
  branchId        String?
  legalEntityId   String?
  checkIn         DateTime?
  checkOut        DateTime?
  totalHours      Decimal?              @db.Decimal(6, 2)
  regularHours    Decimal?              @db.Decimal(6, 2)
  overtimeHours   Decimal?              @db.Decimal(6, 2)
  tardyMinutes    Int?
  status          AttendanceStatus
  color           AttendanceColor
  notes           String?
  isApproved      Boolean               @default(false)
  approvedById    String?
  approvedAt      DateTime?
  closeStatus     AttendanceCloseStatus @default(OPEN)
  closedById      String?
  closedAt        DateTime?
  issues          Json?
  lastProcessedAt DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  HrEmployee      HrEmployee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  ShiftTemplate   ShiftTemplate?        @relation(fields: [shiftTemplateId], references: [id])
  branch          Branch?               @relation(fields: [branchId], references: [id])
  legalEntity     LegalEntity?          @relation(fields: [legalEntityId], references: [id])
  approvedBy      User?                 @relation("AttendanceApprovedBy", fields: [approvedById], references: [id])
  closedBy        User?                 @relation("AttendanceClosedBy", fields: [closedById], references: [id])
  overtimeRequest OvertimeRequest?

  @@unique([employeeId, date])
  @@index([status])
  @@index([branchId])
  @@index([legalEntityId])
}

model AttendanceProcessedDay {
  id               String                    @id @default(cuid())
  employeeId       String
  date             DateTime
  siteId           String?
  customerId       String?
  firstIn          DateTime?
  lastOut          DateTime?
  workedMinutes    Int                       @default(0)
  breakMinutes     Int                       @default(0)
  overtimeMinutes  Int                       @default(0)
  lunchMinutes     Int                       @default(0)
  effectiveMinutes Int                       @default(0)
  lateMinutes      Int                       @default(0)
  status           AttendanceProcessedStatus
  needsApproval    Boolean                   @default(false)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  shiftId          String?
  employee         HrEmployee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift            AttendanceShift?          @relation(fields: [shiftId], references: [id])
  incidents        AttendanceIncident[]

  @@unique([employeeId, date])
  @@index([date])
  @@index([siteId])
  @@index([customerId])
}

model OvertimeRequest {
  id              String                @id @default(cuid())
  employeeId      String
  attendanceDayId String
  calculatedHours Decimal               @db.Decimal(6, 2)
  requestedHours  Decimal               @db.Decimal(6, 2)
