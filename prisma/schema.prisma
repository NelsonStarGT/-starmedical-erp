generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  PROGRAMADA
  CONFIRMADA
  EN_SALA
  ATENDIDA
  NO_SHOW
  CANCELADA
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  FACTURADO
}

enum PartyType {
  CLIENT
  PROVIDER
  PROFESSIONAL
  INSURER
  OTHER
}

enum FlowType {
  INCOME
  EXPENSE
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ORDERED
  RECEIVED_PARTIAL
  RECEIVED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED_PARTIAL
  RECEIVED
  CANCELLED
}

enum InventoryReportFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum InventoryReportType {
  KARDEX
  MOVIMIENTOS
  CIERRE_SAT
}

enum MailModuleKey {
  INVENTARIO
  AGENDA
  FACTURACION
  CONTABILIDAD
  COMPRAS
  ADMIN
  SOPORTE
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum FinancialAccountType {
  CASH
  BANK
  POS
}

enum FinancialTransactionType {
  IN
  OUT
}

enum CreditTerm {
  CASH
  DAYS_15
  DAYS_30
  DAYS_45
  DAYS_60
  DAYS_90
  OTHER
}

enum DocStatus {
  OPEN
  PARTIAL
  PAID
  CANCELLED
}

enum FinanceEntityType {
  CLIENT
  PROVIDER
  EMPLOYEE
  OTHER
}

enum PaymentType {
  AR
  AP
}

enum PaymentMethod {
  CASH
  TRANSFER
  POS
  CHECK
  OTHER
}

enum CrmPipelineType {
  B2B
  B2C
}

enum CrmSlaStatus {
  GREEN
  YELLOW
  RED
}

enum CrmDealStage {
  NUEVO
  CONTACTADO
  DIAGNOSTICO
  COTIZACION
  NEGOCIACION
  GANADO
  PERDIDO
}

enum CrmActivityType {
  CALL
  WHATSAPP
  EMAIL
  VISIT
  NOTE
  SYSTEM
}

enum CrmPreferredChannel {
  CALL
  WHATSAPP
  EMAIL
  VISIT
  VIDEO
}

enum CrmServiceType {
  BOTIQUINES
  EXTINTORES
  CAPACITACIONES
  CLINICAS_EMPRESARIALES
  SSO
  SERVICIOS_MEDICOS
  CONSULTAS
  LABORATORIO
  RAYOS_X
  ULTRASONIDO
  MEMBRESIAS
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum QuoteType {
  B2B
  B2C
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVAL_PENDING
  APPROVED
  REJECTED
}

enum B2BProposalStatus {
  DRAFT
  READY
  SENT
  APPROVED
  REJECTED
  ARCHIVED
}

enum QuoteRequestStatus {
  PENDING
  QUOTED
  CANCELLED
}

enum CrmQuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  WON
}

enum CrmQuoteItemType {
  PRODUCT
  SERVICE
  COMBO
  MANUAL
}

enum CrmLeadType {
  COMPANY
  PATIENT
}

enum CrmLeadStatus {
  NEW
  QUOTED
  FOLLOW_UP
  WON
  LOST
}

enum CrmCalendarEventType {
  VISITA
  REUNION_VIRTUAL
  LLAMADA
  SEGUIMIENTO
}

enum CrmRequestStatus {
  PENDIENTE
  COTIZADA
}

enum ClientProfileType {
  PERSON
  COMPANY
}

enum ApiIntegrationKey {
  WHATSAPP
  SMS
  LABORATORIO
  ASISTENCIA
  SAT_FACTURACION
  GOOGLE_DRIVE
  WEBHOOKS
  OTRO
}

enum PipelineRuleScope {
  PIPELINE
  STAGE
  TRANSITION
}

enum PipelineRuleType {
  REQUIRED_FIELDS
  REQUIRED_NEXT_ACTION
  REQUIRE_QUOTE_STATUS
  DISALLOW_STAGE_FOR_PIPELINE
  REQUIRE_CONTRACT_OR_COLLECTION_PLAN
  REQUIRE_REASON_ON_LOST
  AMOUNT_APPROVAL_THRESHOLD
}

enum RuleSeverity {
  BLOCK
  WARN
}

enum QuoteDeliveryChannel {
  EMAIL
  WHATSAPP
}

enum QuoteDeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
  PENDING_PROVIDER
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String?
  passwordHash        String
  isActive            Boolean             @default(true)
  branchId            String?
  roles               UserRole[]
  dealsOwned          CrmDeal[]           @relation("DealOwnerUser")
  auditLogs           AuditLog[]          @relation("AuditActor")
  fileAssets          FileAsset[]
  b2bProposalsCreated B2BProposalDoc[]    @relation("B2BProposalCreatedBy")
  b2bProposalsUpdated B2BProposalDoc[]    @relation("B2BProposalUpdatedBy")
  deliveries          QuoteDelivery[]     @relation("DeliveryActor")
  ruleEvaluations     RuleEvaluationLog[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  actorUserId String?
  actorRole   String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  before      Json?
  after       Json?
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([entityType, entityId])
  @@index([action])
  @@index([actorUserId])
}

model AppointmentType {
  id           String        @id @default(cuid())
  name         String
  description  String?
  durationMin  Int
  color        String?
  status       String        @default("Activo")
  availability Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Room {
  id           String        @id @default(cuid())
  name         String
  branchId     String
  resource     String
  status       String        @default("Activo")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model WorkSchedule {
  id           String   @id @default(cuid())
  specialistId String
  branchId     String
  weekdays     String[] // ["Lunes","Martes"]
  blocks       Json // [{inicio:"08:00", fin:"12:00"}]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductCategory {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  type          String
  order         Int                  @default(0)
  status        String               @default("Activo")
  subcategories ProductSubcategory[]
  products      Product[]
}

model ProductSubcategory {
  id         String          @id @default(cuid())
  categoryId String
  name       String
  slug       String          @unique
  order      Int             @default(0)
  status     String          @default("Activo")
  category   ProductCategory @relation(fields: [categoryId], references: [id])
  products   Product[]
}

model ServiceCategory {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  area          String
  order         Int                  @default(0)
  status        String               @default("Activo")
  subcategories ServiceSubcategory[]
  services      Service[]
}

model ServiceSubcategory {
  id         String          @id @default(cuid())
  categoryId String
  name       String
  slug       String          @unique
  order      Int             @default(0)
  status     String          @default("Activo")
  category   ServiceCategory @relation(fields: [categoryId], references: [id])
  services   Service[]
}

model InventoryArea {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  order      Int       @default(0)
  isExternal Boolean   @default(true)
  products   Product[]
}

model PriceList {
  id        String          @id @default(cuid())
  name      String
  type      String
  estado    String          @default("Activo")
  items     PriceListItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  itemType    String
  itemId      String
  precio      Float
  priceList   PriceList @relation(fields: [priceListId], references: [id])
}

model Appointment {
  id            String            @id @default(cuid())
  date          DateTime
  durationMin   Int
  patientId     String
  specialistId  String
  branchId      String
  roomId        String?
  typeId        String
  status        AppointmentStatus @default(PROGRAMADA)
  paymentStatus PaymentStatus     @default(PENDIENTE)
  companyId     String?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  createdById   String
  updatedById   String?

  type AppointmentType @relation(fields: [typeId], references: [id])
  room Room?           @relation(fields: [roomId], references: [id])
}

model Product {
  id              String   @id @default(cuid())
  name            String
  code            String   @unique
  categoryId      String
  subcategoryId   String?
  inventoryAreaId String?
  unit            String?
  cost            Decimal  @default(0) @db.Decimal(12, 4)
  price           Decimal  @default(0) @db.Decimal(12, 4)
  baseSalePrice   Decimal  @default(0) @db.Decimal(12, 4)
  avgCost         Decimal  @default(0) @db.Decimal(12, 4)
  marginPct       Float?
  status          String   @default("Activo")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category            ProductCategory       @relation(fields: [categoryId], references: [id])
  subcategory         ProductSubcategory?   @relation(fields: [subcategoryId], references: [id])
  inventoryArea       InventoryArea?        @relation(fields: [inventoryAreaId], references: [id])
  stocks              ProductStock[]
  movements           InventoryMovement[]
  comboLinks          ComboProduct[]
  PurchaseRequestItem PurchaseRequestItem[]
  PurchaseOrderItem   PurchaseOrderItem[]
}

model Service {
  id            String   @id @default(cuid())
  name          String
  code          String?  @unique
  categoryId    String
  subcategoryId String?
  price         Float    @default(0)
  marginPct     Float?
  durationMin   Int      @default(0)
  status        String   @default("Activo")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category    ServiceCategory     @relation(fields: [categoryId], references: [id])
  subcategory ServiceSubcategory? @relation(fields: [subcategoryId], references: [id])
  comboLinks  ComboService[]
}

model ProductStock {
  id        String   @id @default(cuid())
  productId String
  branchId  String
  stock     Int
  minStock  Int
  updatedAt DateTime @default(now()) @updatedAt

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, branchId])
}

model InventoryMovement {
  id          String       @id @default(cuid())
  productId   String
  branchId    String
  type        MovementType
  quantity    Int?
  unitCost    Decimal?     @db.Decimal(12, 4)
  salePrice   Decimal?     @db.Decimal(12, 4)
  reference   String?
  reason      String?
  createdById String
  createdAt   DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
}

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  COST_UPDATE
  PRICE_UPDATE
}

model PurchaseRequest {
  id            String                @id @default(cuid())
  code          String                @unique
  branchId      String
  requestedById String
  status        PurchaseRequestStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  items         PurchaseRequestItem[]
  orders        PurchaseOrder[]
}

model PurchaseRequestItem {
  id                String  @id @default(cuid())
  purchaseRequestId String
  productId         String
  quantity          Int
  unitId            String?
  supplierId        String?
  notes             String?

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  code        String              @unique
  supplierId  String
  branchId    String
  createdById String
  status      PurchaseOrderStatus @default(DRAFT)
  requestId   String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  request PurchaseRequest?    @relation(fields: [requestId], references: [id])
  items   PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Decimal? @db.Decimal(12, 2)
  receivedQty     Int      @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

model Combo {
  id                String         @id @default(cuid())
  name              String
  description       String?
  priceFinal        Decimal        @default(0) @db.Decimal(12, 4)
  costProductsTotal Decimal        @default(0) @db.Decimal(12, 4)
  costCalculated    Decimal        @default(0) @db.Decimal(12, 4)
  imageUrl          String?
  status            String         @default("Activo")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  services          ComboService[]
  products          ComboProduct[]
}

model ComboService {
  id        String  @id @default(cuid())
  comboId   String
  serviceId String
  combo     Combo   @relation(fields: [comboId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@unique([comboId, serviceId])
}

model ComboProduct {
  id        String   @id @default(cuid())
  comboId   String
  productId String
  quantity  Int      @default(1)
  unitCost  Decimal? @db.Decimal(12, 4)
  combo     Combo    @relation(fields: [comboId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([comboId, productId])
}

model InventoryEmailSetting {
  id                 String                   @id @default(cuid())
  isEnabled          Boolean                  @default(true)
  frequency          InventoryReportFrequency
  reportType         InventoryReportType      @default(KARDEX)
  branchId           String?
  recipients         String
  recipientsJson     String                   @default("[]")
  includeAllProducts Boolean                  @default(true)
  scheduleType       String                   @default("BIWEEKLY")
  oneTimeDate        DateTime?
  oneTimeTime        String?
  sentAt             DateTime?
  sendTime           String                   @default("23:30")
  timezone           String                   @default("America/Guatemala")
  biweeklyMode       String?                  @default("FIXED_DAYS")
  fixedDays          String?
  startDate          DateTime?
  monthlyDay         Int?
  useLastDay         Boolean?                 @default(true)
  lastSentAt         DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  logs InventoryReportLog[]
}

model InventoryEmailSchedule {
  id           String              @id @default(cuid())
  email        String
  isEnabled    Boolean             @default(true)
  reportType   InventoryReportType @default(KARDEX)
  branchId     String?
  scheduleType String              @default("ONE_TIME")
  sendTime     String              @default("23:30")
  timezone     String              @default("America/Guatemala")
  oneTimeDate  DateTime?
  monthlyDay   Int?
  useLastDay   Boolean?            @default(true)
  biweeklyMode String?             @default("FIXED_DAYS")
  fixedDays    String?
  startDate    DateTime?
  lastSentAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  logs InventoryEmailScheduleLog[]
}

model InventoryEmailScheduleLog {
  id         String              @id @default(cuid())
  scheduleId String
  reportType InventoryReportType
  periodFrom DateTime
  periodTo   DateTime
  sentAt     DateTime            @default(now())
  status     String
  error      String?

  schedule InventoryEmailSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

model MailGlobalConfig {
  id         String   @id @default(cuid())
  provider   String?
  smtpHost   String
  smtpPort   Int
  smtpSecure Boolean  @default(true)
  imapHost   String
  imapPort   Int
  imapSecure Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model MailModuleAccount {
  id            String        @id @default(cuid())
  moduleKey     MailModuleKey @unique
  email         String
  username      String
  passwordEnc   String
  fromName      String?
  fromEmail     String?
  isEnabled     Boolean       @default(true)
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime      @updatedAt
  createdAt     DateTime      @default(now())
}

model AppConfig {
  id             String   @id @default(cuid())
  companyName    String
  companyNit     String?
  companyPhone   String?
  companyAddress String?
  brandColor     String?
  logoUrl        String?
  timezone       String   @default("America/Guatemala")
  openingHours   Json?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model InvoiceConfig {
  id                String   @id @default(cuid())
  legalName         String
  nit               String
  fiscalAddress     String?
  defaultTaxRate    Int      @default(12)
  invoiceFooterText String?
  pdfTemplateConfig Json?
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  series InvoiceSeries[]
}

model InvoiceSeries {
  id              String   @id @default(cuid())
  invoiceConfigId String
  code            String
  initialNumber   Int      @default(1)
  currentNumber   Int      @default(1)
  branchId        String?
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  invoiceConfig InvoiceConfig @relation(fields: [invoiceConfigId], references: [id], onDelete: Cascade)

  @@unique([invoiceConfigId, code, branchId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model AttendanceIntegrationConfig {
  id            String    @id @default(cuid())
  provider      String
  apiUrl        String?
  apiKeyEnc     String?
  enabled       Boolean   @default(true)
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
}

model LabIntegrationConfig {
  id            String    @id @default(cuid())
  provider      String
  apiUrl        String?
  apiKeyEnc     String?
  enabled       Boolean   @default(true)
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
}

model ApiIntegrationConfig {
  id            String            @id @default(cuid())
  key           ApiIntegrationKey @unique
  name          String
  isEnabled     Boolean           @default(false)
  baseUrl       String?
  apiKeyEnc     String?
  apiSecretEnc  String?
  tokenEnc      String?
  extraJson     String?
  lastTestAt    DateTime?
  lastTestError String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model LegalEntity {
  id                String             @id @default(cuid())
  name              String
  comercialName     String?
  nit               String?
  fiscalAddress     String?
  phone             String?
  email             String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  financialAccounts FinancialAccount[]
  receivables       Receivable[]
  payables          Payable[]
  payments          Payment[]
  journalEntries    JournalEntry[]
}

model Party {
  id          String       @id @default(cuid())
  type        PartyType
  name        String
  nit         String?
  email       String?
  phone       String?
  address     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  receivables Receivable[]
  payables    Payable[]
}

model FinanceCategory {
  id            String               @id @default(cuid())
  flowType      FlowType
  name          String
  slug          String               @unique
  isActive      Boolean              @default(true)
  order         Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  subcategories FinanceSubcategory[]
  receivables   Receivable[]
  payables      Payable[]
}

model FinanceSubcategory {
  id          String          @id @default(cuid())
  categoryId  String
  name        String
  slug        String          @unique
  isActive    Boolean         @default(true)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  receivables Receivable[]
  payables    Payable[]
}

model FinanceAttachment {
  id           String      @id @default(cuid())
  fileUrl      String
  fileName     String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime    @default(now())
  uploadedById String?
  receivableId String?
  payableId    String?
  paymentId    String?
  receivable   Receivable? @relation("ReceivableAttachments", fields: [receivableId], references: [id], onDelete: Cascade)
  payable      Payable?    @relation("PayableAttachments", fields: [payableId], references: [id], onDelete: Cascade)
  payment      Payment?    @relation("PaymentAttachments", fields: [paymentId], references: [id], onDelete: Cascade)
}

model Account {
  id        String             @id @default(cuid())
  code      String             @unique
  name      String
  type      AccountType
  parentId  String?
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  parent    Account?           @relation("AccountChildren", fields: [parentId], references: [id])
  children  Account[]          @relation("AccountChildren")
  lines     JournalEntryLine[]
}

model JournalEntry {
  id            String             @id @default(cuid())
  date          DateTime
  reference     String?
  description   String?
  branchId      String?
  legalEntityId String?
  sourceType    String?
  sourceId      String?
  createdById   String
  totalDebit    Decimal            @default(0) @db.Decimal(14, 2)
  totalCredit   Decimal            @default(0) @db.Decimal(14, 2)
  status        JournalEntryStatus @default(DRAFT)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lines         JournalEntryLine[]
  legalEntity   LegalEntity?       @relation(fields: [legalEntityId], references: [id])
}

model JournalEntryLine {
  id         String             @id @default(cuid())
  entryId    String
  accountId  String
  debit      Decimal            @default(0) @db.Decimal(14, 2)
  credit     Decimal            @default(0) @db.Decimal(14, 2)
  memo       String?
  entityType FinanceEntityType?
  entityId   String?
  createdAt  DateTime           @default(now())
  entry      JournalEntry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account    Account            @relation(fields: [accountId], references: [id])
}

model FinancialAccount {
  id            String                 @id @default(cuid())
  legalEntityId String
  name          String
  type          FinancialAccountType
  bankName      String?
  accountNumber String?
  currency      String                 @default("GTQ")
  branchId      String?
  isActive      Boolean                @default(true)
