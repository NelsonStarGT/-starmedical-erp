  createdAt   DateTime              @default(now())
  createdById String?
  HrEmployee  HrEmployee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy   User?                 @relation("HrWarningCreatedBy", fields: [createdById], references: [id])
