  createdAt       DateTime    @default(now())
  HrEmployee      HrEmployee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy       User?       @relation("AttendancePunchTokenCreatedBy", fields: [createdByUserId], references: [id])

