// ----------------------------
// Recepción (operativo)
// ----------------------------

model Visit {
  /// Episodio operativo del día para recepción (no es historia clínica).
  /// State machine principal:
  /// ARRIVED -> CHECKED_IN -> IN_QUEUE -> CALLED -> IN_SERVICE -> IN_DIAGNOSTIC -> READY_FOR_DISCHARGE -> CHECKED_OUT
  /// Excepciones: ON_HOLD, CANCELLED, NO_SHOW.
  /// Regla: no permitir CHECKED_OUT si existen ServiceRequests abiertas.
  id                   String                @id @default(cuid())
  patientId            String
  /// Sede operativa (Branch). Requerido para trazabilidad multi-sede.
  siteId               String
  appointmentId        String?
  /// WALK_IN por defecto; usar APPOINTMENT cuando appointmentId exista.
  source               VisitSource           @default(WALK_IN)
  /// Código público de ticket, único por sede + día + área.
  ticketCode           String
  /// Clave de fecha local (YYYY-MM-DD) para garantizar unicidad por día.
  ticketDateKey        String
  /// Área usada para generar el ticket (puede diferir del currentArea si la visita se mueve).
  ticketArea           OperationalArea
  /// Área operativa asignada al ingreso.
  initialArea          OperationalArea
  /// Área operativa actual para flujo en tiempo real.
  currentArea          OperationalArea
  /// Prioridad operativa usada por el motor de colas.
  priority             VisitPriority         @default(NORMAL)
  status               VisitStatus           @default(ARRIVED)
  statusChangedAt      DateTime              @default(now())
  arrivedAt            DateTime              @default(now())
  checkedInAt          DateTime?
  checkedOutAt         DateTime?
  cancelledAt          DateTime?
  noShowAt             DateTime?
  notes                String?
  createdByUserId      String?
  updatedByUserId      String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  patient              ClientProfile         @relation(fields: [patientId], references: [id])
  site                 Branch                @relation(fields: [siteId], references: [id])
  appointment          Appointment?          @relation(fields: [appointmentId], references: [id])
  createdByUser        User?                 @relation("VisitCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser        User?                 @relation("VisitUpdatedBy", fields: [updatedByUserId], references: [id])
  visitVitals          ReceptionVisitVitals?
  events               VisitEvent[]
  queueItems           QueueItem[]
  serviceRequests      ServiceRequest[]
  operationalIncidents OperationalIncident[]

  @@unique([siteId, ticketDateKey, ticketArea, ticketCode])
  @@index([siteId, ticketDateKey, ticketArea])
  @@index([patientId, arrivedAt])
  @@index([siteId, status])
  @@index([siteId, status, createdAt])
  @@index([siteId, currentArea, status])
  @@index([appointmentId])
}

model ReceptionVisitVitals {
  id              String   @id @default(cuid())
  visitId         String   @unique
  siteId          String
  systolicBp      Int
  diastolicBp     Int
  heartRate       Int?
  temperatureC    Float?
  weightKg        Float?
  heightCm        Float?
  observations    String?
  vitalsJson      Json?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  visit           Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  site            Branch   @relation(fields: [siteId], references: [id])
  createdByUser   User?    @relation("ReceptionVisitVitalsCreatedBy", fields: [createdByUserId], references: [id])

  @@index([siteId])
  @@index([createdByUserId])
}

model VisitEvent {
  /// Registro auditable e inmutable de eventos de una visita.
  /// Cada transición de Visit.status debe generar un VisitEvent.
  id                    String               @id @default(cuid())
  visitId               String
  eventType             VisitEventType
  fromStatus            VisitStatus?
  toStatus              VisitStatus?
  area                  OperationalArea?
  queueId               String?
  queueItemId           String?
  serviceRequestId      String?
  operationalIncidentId String?
  note                  String?
  metadata              Json?
  actorUserId           String?
  createdAt             DateTime             @default(now())
  visit                 Visit                @relation(fields: [visitId], references: [id], onDelete: Cascade)
  queue                 Queue?               @relation(fields: [queueId], references: [id])
  queueItem             QueueItem?           @relation(fields: [queueItemId], references: [id])
  serviceRequest        ServiceRequest?      @relation(fields: [serviceRequestId], references: [id])
  operationalIncident   OperationalIncident? @relation(fields: [operationalIncidentId], references: [id])
  actorUser             User?                @relation("VisitEventActor", fields: [actorUserId], references: [id])

  @@index([visitId, createdAt])
  @@index([eventType])
  @@index([actorUserId])
}

model Queue {
  /// Cola operativa por sede + área. Un único registro por combinación.
  id              String          @id @default(cuid())
  siteId          String
  area            OperationalArea
  status          QueueStatus     @default(ACTIVE)
  openedAt        DateTime        @default(now())
  closedAt        DateTime?
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  site            Branch          @relation(fields: [siteId], references: [id])
  createdByUser   User?           @relation("QueueCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser   User?           @relation("QueueUpdatedBy", fields: [updatedByUserId], references: [id])
  items           QueueItem[]
  events          VisitEvent[]

  @@unique([siteId, area])
  @@index([status])
}

model QueueItem {
  /// Turno real en la cola, asociado a una visita.
  id                   String                @id @default(cuid())
  queueId              String
  visitId              String
  status               QueueItemStatus       @default(WAITING)
  /// Prioridad usada para ordenar la cola.
  priority             VisitPriority         @default(NORMAL)
  /// Consultorio/ventanilla asignada (si aplica).
  roomId               String?
  sequence             Int?
  enqueuedAt           DateTime              @default(now())
  calledAt             DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  pausedAt             DateTime?
  notes                String?
  assignedToUserId     String?
  createdByUserId      String?
  updatedByUserId      String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  queue                Queue                 @relation(fields: [queueId], references: [id], onDelete: Cascade)
  visit                Visit                 @relation(fields: [visitId], references: [id], onDelete: Cascade)
  room                 Room?                 @relation(fields: [roomId], references: [id])
  assignedToUser       User?                 @relation("QueueItemAssignee", fields: [assignedToUserId], references: [id])
  createdByUser        User?                 @relation("QueueItemCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser        User?                 @relation("QueueItemUpdatedBy", fields: [updatedByUserId], references: [id])
  events               VisitEvent[]
  operationalIncidents OperationalIncident[]

  @@index([queueId, status])
  @@index([queueId, status, enqueuedAt])
  @@index([visitId])
  @@index([status, enqueuedAt])
  @@index([assignedToUserId, status])
  @@index([roomId])
}

model OperationalIncident {
  /// Incidente operativo reportado durante el flujo de recepción.
  id               String                      @id @default(cuid())
  visitId          String
  queueItemId      String?
  area             OperationalArea?
  type             OperationalIncidentType
  severity         OperationalIncidentSeverity @default(LOW)
  status           OperationalIncidentStatus   @default(OPEN)
  description      String
  metadata         Json?
  reportedByUserId String?
  resolvedByUserId String?
  reportedAt       DateTime                    @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  visit            Visit                       @relation(fields: [visitId], references: [id], onDelete: Cascade)
  queueItem        QueueItem?                  @relation(fields: [queueItemId], references: [id])
  reportedByUser   User?                       @relation("OperationalIncidentReportedBy", fields: [reportedByUserId], references: [id])
  resolvedByUser   User?                       @relation("OperationalIncidentResolvedBy", fields: [resolvedByUserId], references: [id])
  events           VisitEvent[]

  @@index([visitId])
  @@index([status, severity])
  @@index([area])
}

model ServiceRequest {
  /// Solicitud administrativa a áreas diagnósticas (LAB/RX/US) sin invadir módulos clínicos.
  id                String               @id @default(cuid())
  visitId           String
  /// Área destino del servicio (recepción -> área).
  area              OperationalArea
  /// Mientras esté REQUESTED/IN_PROGRESS, bloquea CHECKED_OUT de la visita.
  status            ServiceRequestStatus @default(REQUESTED)
  description       String?
  requestedByUserId String?
  assignedToUserId  String?
  requestedAt       DateTime             @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  externalRef       String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  visit             Visit                @relation(fields: [visitId], references: [id], onDelete: Cascade)
  requestedByUser   User?                @relation("ServiceRequestRequestedBy", fields: [requestedByUserId], references: [id])
  assignedToUser    User?                @relation("ServiceRequestAssignedTo", fields: [assignedToUserId], references: [id])
  events            VisitEvent[]

  @@index([visitId, status])
  @@index([area, status])
  @@index([area, status, createdAt])
  @@index([status, createdAt])
  @@index([requestedAt])
}

model TicketSequence {
