  updatedAt    DateTime                 @updatedAt
  HrEmployee   HrEmployee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy    User?                    @relation("DisciplinaryActionCreatedBy", fields: [createdById], references: [id])
  approvedBy   User?                    @relation("DisciplinaryActionApprovedBy", fields: [approvedById], references: [id])
