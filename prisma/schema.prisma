}

model AttendanceRawEvent {
  id              String                   @id @default(cuid())
  employeeId      String?
  branchId        String?
  siteId          String?
  customerId      String?
  occurredAt      DateTime
  deviceTime      DateTime?
  type            AttendanceRawEventType
  source          AttendanceRawEventSource
  biometricId     String?
  status          AttendanceRawEventStatus @default(NEW)
  errorMessage    String?
  lat             Float?
  lng             Float?
  accuracy        Float?
  zoneStatus      AttendanceZoneStatus?
  photoUrl        String?
  photoHash       String?
  faceStatus      AttendanceFaceStatus?
  faceScore       Float?
  rawPayload      Json?
  payloadJson     Json?
  importBatchId   String?
  createdByUserId String?
  createdAt       DateTime                 @default(now())
  employee        HrEmployee?              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch          Branch?                  @relation("BranchRawEvents", fields: [branchId], references: [id])
  createdBy       User?                    @relation("AttendanceRawEventCreatedBy", fields: [createdByUserId], references: [id])
  incidents       AttendanceIncident[]

