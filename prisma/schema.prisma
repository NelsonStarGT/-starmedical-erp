  @@index([partyId])
}

model Payable {
  id            String              @id @default(cuid())
  legalEntityId String
  partyId       String
  date          DateTime
  dueDate       DateTime?
  amount        Decimal             @db.Decimal(12, 2)
  paidAmount    Decimal             @default(0) @db.Decimal(12, 2)
  status        DocStatus           @default(OPEN)
  reference     String?
  categoryId    String?
  subcategoryId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  attachments   FinanceAttachment[] @relation("PayableAttachments")
  payments      Payment[]
  legalEntity   LegalEntity         @relation(fields: [legalEntityId], references: [id])
  party         Party               @relation(fields: [partyId], references: [id])
  category      FinanceCategory?    @relation(fields: [categoryId], references: [id])
  subcategory   FinanceSubcategory? @relation(fields: [subcategoryId], references: [id])

  @@index([legalEntityId])
  @@index([partyId])
}

model Payment {
  id                 String              @id @default(cuid())
  legalEntityId      String
  type               PaymentType
  receivableId       String?
  payableId          String?
  financialAccountId String
  method             PaymentMethod
  date               DateTime
  amount             Decimal             @db.Decimal(12, 2)
  reference          String?
  createdById        String?
  createdAt          DateTime            @default(now())
  financialAccount   FinancialAccount    @relation(fields: [financialAccountId], references: [id])
  receivable         Receivable?         @relation(fields: [receivableId], references: [id])
  payable            Payable?            @relation(fields: [payableId], references: [id])
  attachments        FinanceAttachment[] @relation("PaymentAttachments")
  legalEntity        LegalEntity         @relation(fields: [legalEntityId], references: [id])
}

model InventoryMarginPolicy {
  id                String   @id @default(cuid())
  marginProductsPct Float?
  marginServicesPct Float?
  roundingMode      String   @default("NONE")
  autoApplyOnCreate Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model InventoryReportLog {
  id         String              @id @default(cuid())
  settingId  String
  reportType InventoryReportType
  periodFrom DateTime
  periodTo   DateTime
  sentAt     DateTime            @default(now())
  status     String
  error      String?

  setting InventoryEmailSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@unique([settingId, periodFrom, periodTo])
}

model CrmLead {
  id           String             @id @default(cuid())
  leadType     CrmLeadType
  clientId     String?
  companyName  String?
  nit          String?
  personName   String?
  personDpi    String?
  email        String?
  phone        String?
  address      String?
  source       String?
  status       CrmLeadStatus      @default(NEW)
  ownerId      String?
  nextActionAt DateTime?
  notes        String?
  createdById  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  client       ClientProfile?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  quotes       CrmQuote[]
  calendar     CrmCalendarEvent[]

  @@index([leadType, status])
  @@index([nit])
  @@index([personDpi])
}

model ClientProfile {
  id          String            @id @default(cuid())
  type        ClientProfileType
  companyName String?
  firstName   String?
  lastName    String?
  nit         String?           @unique
  dpi         String?           @unique
  email       String?
  phone       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  accounts    CrmAccount[]
  contacts    CrmContact[]
  leads       CrmLead[]

  @@index([email, phone])
}

model CrmAccount {
  id          String         @id @default(cuid())
  clientId    String?
  name        String
  nit         String?
  address     String?
  sector      String?
  creditTerm  String?
  status      String         @default("ACTIVE")
  ownerId     String?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  contacts    CrmContact[]
  deals       CrmDeal[]
  activities  CrmActivity[]
  client      ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([nit])
  @@index([ownerId])
}

model CrmContact {
  id          String         @id @default(cuid())
  clientId    String?
  accountId   String?
  type        String         @default("PERSON")
  firstName   String
  lastName    String?
  position    String?
  email       String?
  phone       String?
  phonesJson  Json?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  account     CrmAccount?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  client      ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deals       CrmDeal[]
  activities  CrmActivity[]

  @@index([email, phone])
}

model CrmPipeline {
  id          String             @id @default(cuid())
  type        CrmPipelineType
  name        String
  description String?
  stages      CrmPipelineStage[]
  deals       CrmDeal[]

  @@index([type])
}

model PipelineConfig {
  id          String               @id @default(cuid())
  name        String
  type        CrmPipelineType
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  stages      PipelineStage[]
  transitions PipelineTransition[]
  ruleSets    PipelineRuleSet[]
  evaluations RuleEvaluationLog[]

  @@unique([name, type])
}

model PipelineStage {
  id          String         @id @default(cuid())
  pipelineId  String
  key         String
  name        String
  order       Int
  slaDays     Int            @default(0)
  probability Int            @default(0)
  isTerminal  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  pipeline    PipelineConfig @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, key])
  @@index([pipelineId, order])
}

model PipelineTransition {
  id           String         @id @default(cuid())
  pipelineId   String
  fromStageKey String
  toStageKey   String
  isEnabled    Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  pipeline     PipelineConfig @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId, fromStageKey, toStageKey])
}

model PipelineRuleSet {
  id           String            @id @default(cuid())
  pipelineId   String
  scope        PipelineRuleScope
  stageKey     String?
  fromStageKey String?
  toStageKey   String?
  name         String
  description  String?
  priority     Int               @default(100)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  pipeline     PipelineConfig    @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  rules        PipelineRule[]

  @@index([pipelineId, scope])
  @@index([pipelineId, scope, stageKey])
  @@index([pipelineId, scope, fromStageKey, toStageKey])
}

model PipelineRule {
  id        String           @id @default(cuid())
  ruleSetId String
  type      PipelineRuleType
  severity  RuleSeverity     @default(BLOCK)
  message   String
  params    Json?
  isActive  Boolean          @default(true)
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  ruleSet   PipelineRuleSet  @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@index([ruleSetId, order])
}

model RuleEvaluationLog {
  id             String         @id @default(cuid())
  pipelineId     String
  dealId         String
  fromStageKey   String?
  toStageKey     String?
  allowed        Boolean
  errors         Json?
  warnings       Json?
  evaluatedRules Json?
  actorUserId    String?
  createdAt      DateTime       @default(now())
  pipeline       PipelineConfig @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  actorUser      User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([dealId, createdAt])
}

model CrmPipelineStage {
  id              String       @id @default(cuid())
  pipelineId      String
  stage           CrmDealStage
  probabilityPct  Int
  slaDays         Int
  expectedActions Json?
  order           Int
  pipeline        CrmPipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, stage])
  @@index([pipelineId, order])
}

model CrmDeal {
  id                String                   @id @default(cuid())
  pipelineType      CrmPipelineType
  pipelineId        String?
  stage             CrmDealStage             @default(NUEVO)
  stageEnteredAt    DateTime                 @default(now())
  amountEstimated   Decimal                  @default(0) @db.Decimal(12, 2)
  amount            Decimal                  @default(0) @db.Decimal(12, 2)
  probabilityPct    Int                      @default(0)
  expectedCloseDate DateTime?
  ownerId           String?
  ownerUserId       String?
  branchId          String?
  capturedById      String                   @default("Ventas")
  capturedAt        DateTime                 @default(now())
  accountId         String?
  contactId         String?
  source            String?
  lostReason        String?
  competitor        String?
  slaStatus         CrmSlaStatus             @default(GREEN)
  nextAction        String?
  nextActionAt      DateTime?
  preferredChannel  CrmPreferredChannel?
  preferredAt       DateTime?
  servicesOtherNote String?
  status            String                   @default("OPEN")
  notes             String?
  createdById       String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  ownerUser         User?                    @relation("DealOwnerUser", fields: [ownerUserId], references: [id], onDelete: SetNull)
  account           CrmAccount?              @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact           CrmContact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  pipeline          CrmPipeline?             @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  activities        CrmActivity[]
  tasks             CrmTask[]
  quotes            CrmQuote[]
  requests          CrmRequest[]
  quotesV2          Quote[]
  b2bProposals      B2BProposalDoc[]
  quoteRequestsV2   QuoteRequest[]
  services          CrmDealServiceInterest[]
  stageHistory      CrmDealStageHistory[]
  calendarEvents    CrmCalendarEvent[]
  deliveries        QuoteDelivery[]
  FileAsset         FileAsset[]

  @@index([pipelineType, stage])
  @@index([pipelineId])
  @@index([accountId])
  @@index([contactId])
  @@index([ownerUserId])
  @@index([branchId])
}

model CrmDealStageHistory {
  id          String        @id @default(cuid())
  dealId      String
  fromStage   CrmDealStage?
  toStage     CrmDealStage
  changedAt   DateTime      @default(now())
  changedById String?
  comment     String?
  deal        CrmDeal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, changedAt])
}

model CrmDealServiceInterest {
  id          String         @id @default(cuid())
  dealId      String
  serviceType CrmServiceType
  selected    Boolean        @default(true)
  notes       String?
  deal        CrmDeal        @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, serviceType])
  @@index([dealId])
}

model CrmActivity {
  id               String          @id @default(cuid())
  dealId           String?
  accountId        String?
  contactId        String?
  type             CrmActivityType
  dateTime         DateTime
  summary          String?
  nextStepDateTime DateTime?
  notes            String?
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deal             CrmDeal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  account          CrmAccount?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact          CrmContact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([accountId])
  @@index([contactId])
}

model CrmTask {
  id          String          @id @default(cuid())
  ownerId     String?
  dealId      String?
  dueDate     DateTime
  title       String
  status      CrmTaskStatus   @default(OPEN)
  priority    CrmTaskPriority @default(MEDIUM)
  notes       String?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deal        CrmDeal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([ownerId])
}

model CrmQuote {
  id             String             @id @default(cuid())
  dealId         String?
  leadId         String?
  quoteNumber    Int
  sequence       Int                @default(1)
  isActive       Boolean            @default(false)
  versionLabel   String?
  status         CrmQuoteStatus     @default(DRAFT)
  validUntil     DateTime?
  totalAmount    Decimal            @db.Decimal(12, 2)
  internalCost   Decimal            @default(0) @db.Decimal(12, 2)
  internalMargin Decimal            @default(0) @db.Decimal(12, 2)
  currency       String             @default("GTQ")
  notes          String?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deal           CrmDeal?           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead           CrmLead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  items          CrmQuoteItem[]
  calendarEvents CrmCalendarEvent[]
  requests       CrmQuoteRequest[]

  @@unique([dealId, sequence])
  @@unique([quoteNumber])
  @@index([dealId])
  @@index([leadId])
}

model CrmQuoteItem {
  id                String           @id @default(cuid())
  quoteId           String
  itemType          CrmQuoteItemType
  itemId            String?
  manualDescription String?
  manualUnitPrice   Decimal?         @db.Decimal(12, 2)
  qty               Int
  unitPrice         Decimal          @db.Decimal(12, 2)
  discountPct       Int?
  lineTotal         Decimal          @db.Decimal(12, 2)
  costTotal         Decimal          @default(0) @db.Decimal(12, 2)
  marginTotal       Decimal          @default(0) @db.Decimal(12, 2)
  quote             CrmQuote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model CrmRequest {
  id          String            @id @default(cuid())
  dealId      String
  services    CrmServiceType[]
  description String
  status      CrmRequestStatus  @default(PENDIENTE)
  requestedAt DateTime          @default(now())
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deal        CrmDeal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  quotes      CrmQuoteRequest[]

  @@index([dealId, status])
}

model CrmQuoteRequest {
  quoteId   String
  requestId String
  quote     CrmQuote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  request   CrmRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@id([quoteId, requestId])
}

model CrmCalendarEvent {
  id          String               @id @default(cuid())
  dealId      String?
  leadId      String?
  quoteId     String?
  type        CrmCalendarEventType
  startAt     DateTime
  endAt       DateTime?
  title       String
  notes       String?
  ownerId     String?
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deal        CrmDeal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lead        CrmLead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quote       CrmQuote?            @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([leadId])
  @@index([quoteId])
  @@index([type, startAt])
}

model SequenceCounter {
  id           String   @id @default(cuid())
  key          String   @unique
  currentValue Int
  updatedAt    DateTime @updatedAt
}

model B2BProposalDoc {
  id                 String            @id @default(cuid())
  dealId             String
  sequenceYear       Int
  sequenceNumber     Int
  sequenceLabel      String
  versionNumber      Int               @default(1)
  status             B2BProposalStatus @default(DRAFT)
  title              String?
  contentJson        Json?
  contentText        String?
  totalDeclared      Decimal?          @db.Decimal(14, 2)
  lastPdfFileAssetId String?
  createdByUserId    String?
  updatedByUserId    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deal               CrmDeal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lastPdfFileAsset   FileAsset?        @relation("B2BProposalPdfAsset", fields: [lastPdfFileAssetId], references: [id], onDelete: SetNull)
  createdByUser      User?             @relation("B2BProposalCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser      User?             @relation("B2BProposalUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([sequenceYear, sequenceNumber])
  @@index([dealId, createdAt])
  @@index([status])
}

model Quote {
  id                  String          @id @default(cuid())
  dealId              String
  type                QuoteType
  status              QuoteStatus     @default(DRAFT)
  isActive            Boolean         @default(false)
  number              String          @unique
  issuedAt            DateTime        @default(now())
  createdById         String?
  sentAt              DateTime?
  approvalRequestedAt DateTime?
  approvedAt          DateTime?
  approvedById        String?
  rejectedAt          DateTime?
  rejectedById        String?
  rejectionReason     String?
  templateId          String?
  notes               String?
  validityDays        Int             @default(30)
  currency            String          @default("GTQ")
  subtotal            Decimal         @default(0) @db.Decimal(14, 2)
  discountTotal       Decimal         @default(0) @db.Decimal(14, 2)
  taxTotal            Decimal         @default(0) @db.Decimal(14, 2)
  total               Decimal         @default(0) @db.Decimal(14, 2)
  paymentTerms        String?
  deliveryTime        String?
  deliveryNote        String?
  pricesIncludeTax    Boolean         @default(true)
  chequePayableTo     String?
  pdfUrl              String?
  pdfGeneratedAt      DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deal                CrmDeal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  template            QuoteTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
