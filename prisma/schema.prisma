  updatedAt           DateTime                @updatedAt

  @@unique([siteId])
  @@index([customerId])
}

model AttendanceShift {
  id               String                   @id @default(cuid())
  siteId           String
  name             String
  startTime        String
  endTime          String
  toleranceMinutes Int
  lunchMinutes     Int?
