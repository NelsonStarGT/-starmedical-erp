model HrPayrollRun {
  id               String          @id @default(cuid())
  periodStart      DateTime
  periodEnd        DateTime
  status           String          @default("DRAFT")
  createdByUserId  String?
  approvedByUserId String?
  publishedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
