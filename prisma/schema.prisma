  @@index([branchId])
  @@index([siteId])
  @@index([customerId])
  @@index([biometricId, occurredAt])
  @@index([status])
}

model AttendanceIncident {
  id               String                     @id @default(cuid())
  employeeId       String
  date             DateTime
  type             AttendanceIncidentType
  severity         AttendanceIncidentSeverity
  siteId           String?
  customerId       String?
  rawEventId       String?
  processedDayId   String?
  resolved         Boolean                    @default(false)
  resolvedByUserId String?
  resolvedAt       DateTime?
  notes            String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  employee         HrEmployee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  resolvedBy       User?                      @relation("AttendanceIncidentResolvedBy", fields: [resolvedByUserId], references: [id])
