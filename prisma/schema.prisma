generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                    @id @default(cuid())
  email               String                    @unique
  name                String?
  passwordHash        String
  isActive            Boolean                   @default(true)
  branchId            String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  auditLogs           AuditLog[]                @relation("AuditActor")
  b2bProposalsCreated B2BProposalDoc[]          @relation("B2BProposalCreatedBy")
  b2bProposalsUpdated B2BProposalDoc[]          @relation("B2BProposalUpdatedBy")
  dealsOwned          CrmDeal[]                 @relation("DealOwnerUser")
  uploadedDocuments   EmployeeDocumentVersion[] @relation("DocumentUploadedBy")
  EmployeeEvaluation  EmployeeEvaluation[]
  fileAssets          FileAsset[]
  employee            HrEmployee?               @relation("EmployeeUser")
  LeaveRequest        LeaveRequest[]
  MembershipException MembershipException[]
  payrollRunsApproved PayrollRun[]              @relation("PayrollRunApprovedBy")
  payrollRunsCreated  PayrollRun[]              @relation("PayrollRunCreatedBy")
  deliveries          QuoteDelivery[]           @relation("DeliveryActor")
  ruleEvaluations     RuleEvaluationLog[]
  roles               UserRole[]
  userPermissions     UserPermission[]
  approvedAttendance  AttendanceDay[]           @relation("AttendanceApprovedBy")
  closedAttendance    AttendanceDay[]           @relation("AttendanceClosedBy")
  reviewedOvertime    OvertimeRequest[]         @relation("OvertimeReviewedBy")
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  actorUserId String?
  actorRole   String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  before      Json?
  after       Json?
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([timestamp])
  @@index([entityType, entityId])
  @@index([action])
  @@index([actorUserId])
}

model AppointmentType {
  id           String        @id @default(cuid())
  name         String
  description  String?
  durationMin  Int
  color        String?
  status       String        @default("Activo")
  availability Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Room {
  id           String        @id @default(cuid())
  name         String
  branchId     String
  resource     String
  status       String        @default("Activo")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model WorkSchedule {
  id           String   @id @default(cuid())
  specialistId String
  branchId     String
  weekdays     String[]
  blocks       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductCategory {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  type          String
  order         Int                  @default(0)
  status        String               @default("Activo")
  products      Product[]
  subcategories ProductSubcategory[]
}

model ProductSubcategory {
  id         String          @id @default(cuid())
  categoryId String
  name       String
  slug       String          @unique
  order      Int             @default(0)
  status     String          @default("Activo")
  products   Product[]
  category   ProductCategory @relation(fields: [categoryId], references: [id])
}

model ServiceCategory {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  area          String
  order         Int                  @default(0)
  status        String               @default("Activo")
  services      Service[]
  subcategories ServiceSubcategory[]
}

model ServiceSubcategory {
  id         String          @id @default(cuid())
  categoryId String
  name       String
  slug       String          @unique
  order      Int             @default(0)
  status     String          @default("Activo")
  services   Service[]
  category   ServiceCategory @relation(fields: [categoryId], references: [id])
}

model InventoryArea {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  order      Int       @default(0)
  isExternal Boolean   @default(true)
  products   Product[]
}

model PriceList {
  id        String          @id @default(cuid())
  name      String
  type      String
  estado    String          @default("Activo")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     PriceListItem[]
}

model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  itemType    String
  itemId      String
  precio      Float
  priceList   PriceList @relation(fields: [priceListId], references: [id])
}

model Appointment {
  id            String            @id @default(cuid())
  date          DateTime
  durationMin   Int
  patientId     String
  specialistId  String
  branchId      String
  roomId        String?
  typeId        String
  status        AppointmentStatus @default(PROGRAMADA)
  paymentStatus PaymentStatus     @default(PENDIENTE)
  companyId     String?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  createdById   String
  updatedById   String?
  room          Room?             @relation(fields: [roomId], references: [id])
  type          AppointmentType   @relation(fields: [typeId], references: [id])
}

model Product {
  id                  String                @id @default(cuid())
  name                String
  code                String                @unique
  categoryId          String
  subcategoryId       String?
  inventoryAreaId     String?
  unit                String?
  cost                Decimal               @default(0) @db.Decimal(12, 4)
  price               Decimal               @default(0) @db.Decimal(12, 4)
  status              String                @default("Activo")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  avgCost             Decimal               @default(0) @db.Decimal(12, 4)
  baseSalePrice       Decimal               @default(0) @db.Decimal(12, 4)
  marginPct           Float?
  comboLinks          ComboProduct[]
  movements           InventoryMovement[]
  category            ProductCategory       @relation(fields: [categoryId], references: [id])
  inventoryArea       InventoryArea?        @relation(fields: [inventoryAreaId], references: [id])
  subcategory         ProductSubcategory?   @relation(fields: [subcategoryId], references: [id])
  stocks              ProductStock[]
  PurchaseOrderItem   PurchaseOrderItem[]
  PurchaseRequestItem PurchaseRequestItem[]
}

model Service {
  id            String              @id @default(cuid())
  name          String
  code          String?             @unique
  categoryId    String
  subcategoryId String?
  price         Float               @default(0)
  durationMin   Int                 @default(0)
  status        String              @default("Activo")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  marginPct     Float?
  comboLinks    ComboService[]
  category      ServiceCategory     @relation(fields: [categoryId], references: [id])
  subcategory   ServiceSubcategory? @relation(fields: [subcategoryId], references: [id])
}

model ProductStock {
  id        String   @id @default(cuid())
  productId String
  branchId  String
  stock     Int
  minStock  Int
  updatedAt DateTime @default(now()) @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([productId, branchId])
}

model InventoryMovement {
  id          String       @id @default(cuid())
  productId   String
  branchId    String
  type        MovementType
  quantity    Int?
  unitCost    Decimal?     @db.Decimal(12, 4)
  salePrice   Decimal?     @db.Decimal(12, 4)
  reference   String?
  reason      String?
  createdById String
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id])
}

model PurchaseRequest {
  id            String                @id @default(cuid())
  code          String                @unique
  branchId      String
  requestedById String
  status        PurchaseRequestStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  orders        PurchaseOrder[]
  items         PurchaseRequestItem[]
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  productId         String
  quantity          Int
  unitId            String?
  supplierId        String?
  notes             String?
  product           Product         @relation(fields: [productId], references: [id])
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  code        String              @unique
  supplierId  String
  branchId    String
  createdById String
  status      PurchaseOrderStatus @default(DRAFT)
  requestId   String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  request     PurchaseRequest?    @relation(fields: [requestId], references: [id])
  items       PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Decimal?      @db.Decimal(12, 2)
  receivedQty     Int           @default(0)
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model Combo {
  id                String         @id @default(cuid())
  name              String
  description       String?
  priceFinal        Decimal        @default(0) @db.Decimal(12, 4)
  costProductsTotal Decimal        @default(0) @db.Decimal(12, 4)
  costCalculated    Decimal        @default(0) @db.Decimal(12, 4)
  imageUrl          String?
  status            String         @default("Activo")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  products          ComboProduct[]
  services          ComboService[]
}

model ComboService {
  id        String  @id @default(cuid())
  comboId   String
  serviceId String
  combo     Combo   @relation(fields: [comboId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@unique([comboId, serviceId])
}

model ComboProduct {
  id        String   @id @default(cuid())
  comboId   String
  productId String
  quantity  Int      @default(1)
  unitCost  Decimal? @db.Decimal(12, 4)
  combo     Combo    @relation(fields: [comboId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([comboId, productId])
}

model InventoryEmailSetting {
  id                 String                   @id @default(cuid())
  isEnabled          Boolean                  @default(true)
  frequency          InventoryReportFrequency
  branchId           String?
  recipients         String
  includeAllProducts Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  lastSentAt         DateTime?
  reportType         InventoryReportType      @default(KARDEX)
  biweeklyMode       String?                  @default("FIXED_DAYS")
  fixedDays          String?
  monthlyDay         Int?
  recipientsJson     String                   @default("[]")
  scheduleType       String                   @default("BIWEEKLY")
  sendTime           String                   @default("23:30")
  startDate          DateTime?
  timezone           String                   @default("America/Guatemala")
  useLastDay         Boolean?                 @default(true)
  oneTimeDate        DateTime?
  oneTimeTime        String?
  sentAt             DateTime?
  logs               InventoryReportLog[]
}

model InventoryEmailSchedule {
  id           String                      @id @default(cuid())
  email        String
  isEnabled    Boolean                     @default(true)
  reportType   InventoryReportType         @default(KARDEX)
  branchId     String?
  scheduleType String                      @default("ONE_TIME")
  sendTime     String                      @default("23:30")
  timezone     String                      @default("America/Guatemala")
  oneTimeDate  DateTime?
  monthlyDay   Int?
  useLastDay   Boolean?                    @default(true)
  biweeklyMode String?                     @default("FIXED_DAYS")
  fixedDays    String?
  startDate    DateTime?
  lastSentAt   DateTime?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  logs         InventoryEmailScheduleLog[]
}

model InventoryEmailScheduleLog {
  id         String                 @id @default(cuid())
  scheduleId String
  reportType InventoryReportType
  periodFrom DateTime
  periodTo   DateTime
  sentAt     DateTime               @default(now())
  status     String
  error      String?
  schedule   InventoryEmailSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

model MailGlobalConfig {
  id         String   @id @default(cuid())
  provider   String?
  smtpHost   String
  smtpPort   Int
  smtpSecure Boolean  @default(true)
  imapHost   String
  imapPort   Int
  imapSecure Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model MailModuleAccount {
  id            String        @id @default(cuid())
  moduleKey     MailModuleKey @unique
  email         String
  username      String
  passwordEnc   String
  fromName      String?
  fromEmail     String?
  isEnabled     Boolean       @default(true)
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime      @updatedAt
  createdAt     DateTime      @default(now())
}

model AppConfig {
  id             String   @id @default(cuid())
  companyName    String
  companyNit     String?
  companyPhone   String?
  companyAddress String?
  logoUrl        String?
  timezone       String   @default("America/Guatemala")
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  brandColor     String?
  openingHours   Json?
}

model InvoiceConfig {
  id                String          @id @default(cuid())
  legalName         String
  nit               String
  fiscalAddress     String?
  defaultTaxRate    Int             @default(12)
  invoiceFooterText String?
  pdfTemplateConfig Json?
  updatedAt         DateTime        @updatedAt
  createdAt         DateTime        @default(now())
  series            InvoiceSeries[]
}

model InvoiceSeries {
  id              String        @id @default(cuid())
  invoiceConfigId String
  code            String
  initialNumber   Int           @default(1)
  currentNumber   Int           @default(1)
  branchId        String?
  isActive        Boolean       @default(true)
  updatedAt       DateTime      @updatedAt
  createdAt       DateTime      @default(now())
  invoiceConfig   InvoiceConfig @relation(fields: [invoiceConfigId], references: [id], onDelete: Cascade)

  @@unique([invoiceConfigId, code, branchId])
}

model Role {
  id            String           @id @default(cuid())
  name          String           @unique
  description   String?
  isSystem      Boolean          @default(false)
  legalEntityId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  permissions   RolePermission[]
  userRoles     UserRole[]
  legalEntity   LegalEntity?     @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
}

model Permission {
  id               String               @id @default(cuid())
  key              String               @unique
  module           String               @default("GENERAL")
  area             String               @default("CORE")
  action           String               @default("READ")
  description      String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  roles            RolePermission[]
  userPermissions  UserPermission[]

  @@index([module, area, action])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserPermission {
  id            String                 @id @default(cuid())
  userId        String
  permissionId  String
  effect        UserPermissionEffect
  reason        String?
  legalEntityId String?
  createdAt     DateTime               @default(now())
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission    Permission             @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  legalEntity   LegalEntity?           @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId, legalEntityId])
}

model AttendanceIntegrationConfig {
  id            String    @id @default(cuid())
  provider      String
  apiUrl        String?
  apiKeyEnc     String?
  enabled       Boolean   @default(true)
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
}

model LabIntegrationConfig {
  id            String    @id @default(cuid())
  provider      String
  apiUrl        String?
  apiKeyEnc     String?
  enabled       Boolean   @default(true)
  lastTestAt    DateTime?
  lastTestError String?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
}

model ApiIntegrationConfig {
  id            String            @id @default(cuid())
  key           ApiIntegrationKey @unique
  name          String
  isEnabled     Boolean           @default(false)
  baseUrl       String?
  apiKeyEnc     String?
  apiSecretEnc  String?
  tokenEnc      String?
  extraJson     String?
  lastTestAt    DateTime?
  lastTestError String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model LegalEntity {
  id                 String               @id @default(cuid())
  name               String
  comercialName      String?
  nit                String?
  fiscalAddress      String?
  phone              String?
  email              String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  EmployeeEngagement EmployeeEngagement[]
  financialAccounts  FinancialAccount[]
  HrEmployee         HrEmployee[]
  journalEntries     JournalEntry[]
  payables           Payable[]
  payments           Payment[]
  PayrollRun         PayrollRun[]
  receivables        Receivable[]
  timeClockDevices   TimeClockDevice[]
  timeClockLogs      TimeClockLog[]
  attendanceDays     AttendanceDay[]
  roles              Role[]
  userPermissions    UserPermission[]
}

model Party {
  id          String       @id @default(cuid())
  type        PartyType
  name        String
  nit         String?
  email       String?
  phone       String?
  address     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  payables    Payable[]
  receivables Receivable[]
}

model FinanceCategory {
  id            String               @id @default(cuid())
  flowType      FlowType
  name          String
  slug          String               @unique
  isActive      Boolean              @default(true)
  order         Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  subcategories FinanceSubcategory[]
  payables      Payable[]
  receivables   Receivable[]
}

model FinanceSubcategory {
  id          String          @id @default(cuid())
  categoryId  String
  name        String
  slug        String          @unique
  isActive    Boolean         @default(true)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  payables    Payable[]
  receivables Receivable[]
}

model FinanceAttachment {
  id           String      @id @default(cuid())
  fileUrl      String
  fileName     String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime    @default(now())
  uploadedById String?
  receivableId String?
  payableId    String?
  paymentId    String?
  payable      Payable?    @relation("PayableAttachments", fields: [payableId], references: [id], onDelete: Cascade)
  payment      Payment?    @relation("PaymentAttachments", fields: [paymentId], references: [id], onDelete: Cascade)
  receivable   Receivable? @relation("ReceivableAttachments", fields: [receivableId], references: [id], onDelete: Cascade)
}

model Account {
  id        String             @id @default(cuid())
  code      String             @unique
  name      String
  type      AccountType
  parentId  String?
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  parent    Account?           @relation("AccountChildren", fields: [parentId], references: [id])
  children  Account[]          @relation("AccountChildren")
  lines     JournalEntryLine[]
}

model JournalEntry {
  id            String             @id @default(cuid())
  date          DateTime
  reference     String?
  description   String?
  branchId      String?
  createdById   String
  totalDebit    Decimal            @default(0) @db.Decimal(14, 2)
  totalCredit   Decimal            @default(0) @db.Decimal(14, 2)
  status        JournalEntryStatus @default(DRAFT)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  legalEntityId String?
  sourceId      String?
  sourceType    String?
  legalEntity   LegalEntity?       @relation(fields: [legalEntityId], references: [id])
  lines         JournalEntryLine[]
}

model JournalEntryLine {
  id         String             @id @default(cuid())
  entryId    String
  accountId  String
  debit      Decimal            @default(0) @db.Decimal(14, 2)
  credit     Decimal            @default(0) @db.Decimal(14, 2)
  memo       String?
  entityType FinanceEntityType?
  entityId   String?
  createdAt  DateTime           @default(now())
  account    Account            @relation(fields: [accountId], references: [id])
  entry      JournalEntry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model FinancialAccount {
  id            String                 @id @default(cuid())
  name          String
  type          FinancialAccountType
  currency      String                 @default("GTQ")
  branchId      String?
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  accountNumber String?
  bankName      String?
  legalEntityId String
  legalEntity   LegalEntity            @relation(fields: [legalEntityId], references: [id])
  entries       FinancialTransaction[]
  payments      Payment[]

  @@index([legalEntityId])
}

model FinancialTransaction {
  id                 String                   @id @default(cuid())
  financialAccountId String
  date               DateTime
  amount             Decimal                  @db.Decimal(14, 2)
  type               FinancialTransactionType
  description        String
  reference          String?
  createdById        String
  createdAt          DateTime                 @default(now())
  account            FinancialAccount         @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
}

model Receivable {
  id            String              @id @default(cuid())
  date          DateTime
  dueDate       DateTime?
  amount        Decimal             @db.Decimal(12, 2)
  paidAmount    Decimal             @default(0) @db.Decimal(12, 2)
  reference     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  categoryId    String?
  creditTerm    CreditTerm          @default(CASH)
  legalEntityId String
  partyId       String
  subcategoryId String?
  status        DocStatus           @default(OPEN)
  attachments   FinanceAttachment[] @relation("ReceivableAttachments")
  payments      Payment[]
  category      FinanceCategory?    @relation(fields: [categoryId], references: [id])
  legalEntity   LegalEntity         @relation(fields: [legalEntityId], references: [id])
  party         Party               @relation(fields: [partyId], references: [id])
  subcategory   FinanceSubcategory? @relation(fields: [subcategoryId], references: [id])

  @@index([legalEntityId])
  @@index([partyId])
}

model Payable {
  id            String              @id @default(cuid())
  date          DateTime
  dueDate       DateTime?
  amount        Decimal             @db.Decimal(12, 2)
  paidAmount    Decimal             @default(0) @db.Decimal(12, 2)
  reference     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  categoryId    String?
  legalEntityId String
  partyId       String
  subcategoryId String?
  status        DocStatus           @default(OPEN)
  attachments   FinanceAttachment[] @relation("PayableAttachments")
  category      FinanceCategory?    @relation(fields: [categoryId], references: [id])
  legalEntity   LegalEntity         @relation(fields: [legalEntityId], references: [id])
  party         Party               @relation(fields: [partyId], references: [id])
  subcategory   FinanceSubcategory? @relation(fields: [subcategoryId], references: [id])
  payments      Payment[]
  payrollFinanceRecords PayrollFinanceRecord[]

  @@index([legalEntityId])
  @@index([partyId])
}

model Payment {
  id                 String              @id @default(cuid())
  type               PaymentType
  receivableId       String?
  payableId          String?
  financialAccountId String
  date               DateTime
  amount             Decimal             @db.Decimal(12, 2)
  reference          String?
  createdById        String?
  createdAt          DateTime            @default(now())
  legalEntityId      String
  method             PaymentMethod
  attachments        FinanceAttachment[] @relation("PaymentAttachments")
  financialAccount   FinancialAccount    @relation(fields: [financialAccountId], references: [id])
  legalEntity        LegalEntity         @relation(fields: [legalEntityId], references: [id])
  payable            Payable?            @relation(fields: [payableId], references: [id])
  receivable         Receivable?         @relation(fields: [receivableId], references: [id])
}

model InventoryMarginPolicy {
  id                String   @id @default(cuid())
  marginProductsPct Float?
  marginServicesPct Float?
  roundingMode      String   @default("NONE")
