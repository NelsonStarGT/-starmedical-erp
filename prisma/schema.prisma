  processedDay     AttendanceProcessedDay?    @relation(fields: [processedDayId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date, type])
  @@index([date])
  @@index([siteId])
  @@index([resolved])
}

model AttendanceSiteConfig {
