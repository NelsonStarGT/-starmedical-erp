{
  "name": "star-medical-erp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "sh -c 'if [ \"${PRISMA_AUTO_MIGRATE:-0}\" = \"1\" ]; then npm run db:migrate:safe; fi && next dev'",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "check:legacy:recepcion": "bash scripts/check-no-legacy-recepcion.sh",
    "typecheck:clients": "tsc --noEmit -p tsconfig.clients.json",
    "test": "AUTH_SECRET=\"${AUTH_SECRET:-test-star-secret}\" tsx --tsconfig tsconfig.test.json --test \"tests/**/*.test.ts\" \"src/tests/**/*.test.ts\"",
    "test:baseline": "AUTH_SECRET=\"${AUTH_SECRET:-test-star-secret}\" tsx --tsconfig tsconfig.test.json --test \"tests/**/*.test.ts\" \"src/tests/**/*.test.ts\" --test-reporter=spec --test-concurrency=1",
    "test:legacy": "tsx --tsconfig tsconfig.test.json --test \"tests/memberships.db.test.ts\" --test-reporter=spec --test-concurrency=1",
    "test:legacy:run": "RUN_LEGACY_TESTS=1 tsx --tsconfig tsconfig.test.json --test \"tests/memberships.db.test.ts\" --test-reporter=spec --test-concurrency=1",
    "qa": "npm run lint && npm run typecheck && npm run test",
    "qa:repo:inventory": "node scripts/qa/repo-inventory.mjs",
    "qa:ui:tokens": "node scripts/qa/check-ui-brand-tokens.mjs",
    "qa:ui:tokens:baseline": "node scripts/qa/check-ui-brand-tokens.mjs --update-baseline",
    "smoke": "node scripts/smoke-test.js",
    "smoke:ci": "node scripts/smoke-ci.cjs",
    "audit:enums": "node scripts/audit-enums.mjs",
    "db:up": "docker compose up -d --remove-orphans",
    "db:down": "docker compose down --remove-orphans",
    "db:wait": "bash scripts/dev/db-wait.sh",
    "db:logs": "docker compose logs -f db",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:safe": "bash scripts/dev/db-migrate-safe.sh",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:drift:check": "bash scripts/check-migration-drift.sh",
    "db:migrate:diff": "sh -c 'test -n \"$SHADOW_DATABASE_URL\" || (echo \"SHADOW_DATABASE_URL is required\" && exit 1); prisma migrate diff --exit-code --from-schema-datasource prisma/schema.prisma --to-migrations prisma/migrations --shadow-database-url \"$SHADOW_DATABASE_URL\"'",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:dev": "prisma db seed --schema prisma/schema.prisma",
    "db:seed:core": "tsx prisma/seed.core.ts",
    "db:seed:clients": "tsx prisma/seed.clients.ts",
    "db:seed:geo:geonames": "tsx scripts/geo/import-geonames.ts",
    "db:seed:geo:ine-gt": "tsx scripts/geo/import-ine-gt.ts",
    "db:seed:geo:america": "tsx scripts/geo/import-america.ts",
    "db:seed:geo:europe": "tsx scripts/geo/import-europe.ts",
    "db:seed:central-config": "tsx prisma/seed.central-config.ts",
    "qa:config-central": "bash scripts/qa/config-central.sh",
    "qa:config-central:readiness": "tsx scripts/qa/config-central-readiness.ts",
    "ops:events:purge": "tsx scripts/ops/purge-system-event-log.ts",
    "medical:cie10:import": "tsx scripts/medical/import-cie10.ts",
    "portal:link-party": "tsx scripts/portal/link-client-party.ts",
    "db:validate": "prisma validate",
    "db:check": "prisma validate && prisma migrate status",
    "db:reset": "bash scripts/dev/db-reset.sh",
    "db:reset:dev": "bash scripts/dev/db-reset-dev.sh",
    "dev:setup": "npm run db:generate && npm run db:migrate:deploy && npm run db:seed",
    "dev:reset": "npm run db:reset",
    "dev:seed:auth": "node scripts/dev/seed-auth.ts",
    "dev:grant-role": "tsx scripts/grant-role.ts",
    "dev:clean": "rm -rf .next && next dev",
    "inventory:reset": "sh -c 'if [ \"$NODE_ENV\" = \"production\" ]; then echo \"inventory:reset bloqueado en production\" && exit 1; else curl -X POST -H \"x-reset-confirm: YES\" -H \"Content-Type: application/json\" -d \"{\\\"mode\\\":\\\"wipe_movements\\\"}\" http://localhost:3000/api/inventario/reset; fi'",
    "bootstrap:superadmin": "tsx scripts/bootstrap-super-admin.ts",
    "bootstrap:emergency-admin": "tsx scripts/create-emergency-admin.ts",
    "backfill:user-job-roles": "ts-node scripts/backfill-user-job-roles.ts",
    "backfill:client-codes": "tsx scripts/ops/backfill-client-codes.ts",
    "backfill:client-codes:dry-run": "tsx scripts/ops/backfill-client-codes.ts --dry-run",
    "inventory:hardening:audit": "tsx scripts/inventory/hardening-data.ts",
    "inventory:hardening:apply": "tsx scripts/inventory/hardening-data.ts --apply",
    "clients:bulk:templates": "tsx scripts/clients/generate-bulk-templates.ts",
    "clients:audit:data": "tsx scripts/clients/audit-data.ts",
    "check:tenant:isolation": "bash scripts/check-tenant-scope.sh"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.5",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-query": "^5.62.8",
    "@tiptap/extension-color": "^2.11.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/extension-task-item": "^2.11.5",
    "@tiptap/extension-task-list": "^2.11.5",
    "@tiptap/extension-text-align": "^2.11.5",
    "@tiptap/extension-text-style": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@types/dompurify": "3.0.5",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "dompurify": "3.3.1",
    "html-to-docx": "^1.6.1",
    "html2pdf.js": "0.14.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.469.0",
    "next": "16.1.6",
    "nodemailer": "^7.0.12",
    "pdf-lib": "^1.17.1",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.53.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.7.0",
    "redis": "^4.7.1",
    "server-only": "^0.0.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.0.10",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "markdown-it": "14.1.1"
  }
}
