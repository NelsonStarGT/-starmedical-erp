{
  "name": "star-medical-erp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "typecheck:clients": "tsc --noEmit -p tsconfig.clients.json",
    "test": "tsx --test \"tests/**/*.test.ts\" \"src/tests/**/*.test.ts\"",
    "qa": "npm run lint && npm run typecheck && npm run test",
    "smoke": "node scripts/smoke-test.js",
    "smoke:ci": "node scripts/smoke-ci.cjs",
    "audit:enums": "node scripts/audit-enums.mjs",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:diff": "sh -c 'test -n \"$SHADOW_DATABASE_URL\" || (echo \"SHADOW_DATABASE_URL is required\" && exit 1); prisma migrate diff --exit-code --from-schema-datasource prisma/schema.prisma --to-migrations prisma/migrations --shadow-database-url \"$SHADOW_DATABASE_URL\"'",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:core": "tsx prisma/seed.core.ts",
    "db:seed:clients": "tsx prisma/seed.clients.ts",
    "medical:cie10:import": "tsx scripts/medical/import-cie10.ts",
    "portal:link-party": "tsx scripts/portal/link-client-party.ts",
    "db:validate": "prisma validate",
    "db:check": "prisma validate && prisma migrate status",
    "db:reset": "sh -c 'if [ \"$NODE_ENV\" = \"production\" ]; then echo \"db:reset bloqueado en production\" && exit 1; fi; set -e; docker compose down -v; docker compose up -d db; until docker exec starmedical-db pg_isready -U postgres -d starmedical >/dev/null 2>&1; do sleep 1; done; npx prisma migrate dev --name baseline-apply --create-only=false; npx prisma db seed'",
    "dev:setup": "npm run db:generate && npm run db:migrate:deploy && npm run db:seed",
    "dev:reset": "npm run db:reset",
    "dev:clean": "rm -rf .next && next dev",
    "inventory:reset": "sh -c 'if [ \"$NODE_ENV\" = \"production\" ]; then echo \"inventory:reset bloqueado en production\" && exit 1; else curl -X POST -H \"x-reset-confirm: YES\" -H \"Content-Type: application/json\" -d \"{\\\"mode\\\":\\\"wipe_movements\\\"}\" http://localhost:3000/api/inventario/reset; fi'",
    "bootstrap:superadmin": "tsx scripts/bootstrap-super-admin.ts",
    "backfill:user-job-roles": "ts-node scripts/backfill-user-job-roles.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.5",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-query": "^5.62.8",
    "@tiptap/extension-color": "^2.11.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/extension-task-item": "^2.11.5",
    "@tiptap/extension-task-list": "^2.11.5",
    "@tiptap/extension-text-align": "^2.11.5",
    "@tiptap/extension-text-style": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@types/dompurify": "3.0.5",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "dompurify": "3.3.1",
    "exceljs": "^4.4.0",
    "html-to-docx": "^1.6.1",
    "html2pdf.js": "0.14.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.469.0",
    "next": "16.1.6",
    "nodemailer": "^7.0.12",
    "pdf-lib": "^1.17.1",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.53.0",
    "redis": "^4.7.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.0.10",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
